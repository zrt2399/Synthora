<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    x:ClassModifier="internal"
                    x:CompileBindings="True">

    <Design.PreviewWith>
        <Border Width="400" Height="600">
            <NavigationPage />
        </Border>
    </Design.PreviewWith>

    <x:Double x:Key="NavigationPageBarHeight">36</x:Double>

    <ControlTheme x:Key="NavigationPageBackButtonTheme" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Width" Value="{Binding $self.Bounds.Height}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="boder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Margin="{TemplateBinding Padding}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      RecognizesAccessKey="True"
                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                </Border>
            </ControlTemplate>
        </Setter>

        <!--  Hover  -->
        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{DynamicResource ThemeSelectedLowColor}" />
        </Style>

        <!--  Pressed  -->
        <Style Selector="^:pressed">
            <Setter Property="Background" Value="{DynamicResource ThemeSelectedMidColor}" />
        </Style>

        <Style Selector="^:disabled /template/ ContentPresenter#PART_IconPresenter">
            <Setter Property="Opacity" Value="{DynamicResource ThemeDisabledOpacity}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type NavigationPage}" TargetType="NavigationPage">
        <Setter Property="BarHeight" Value="{DynamicResource NavigationPageBarHeight}" />
        <!-- <Setter Property="Background" Value="Transparent" /> -->
        <Setter Property="PageTransition">
            <Setter.Value>
                <PageSlide FillMode="Forward"
                           Orientation="Horizontal"
                           Duration="0:0:0.3">
                    <PageSlide.SlideInEasing>
                        <SplineEasing X1="0.16"
                                      X2="0.3"
                                      Y1="1"
                                      Y2="1" />
                    </PageSlide.SlideInEasing>
                    <PageSlide.SlideOutEasing>
                        <SplineEasing X1="0.2"
                                      X2="0.3"
                                      Y1="0.85"
                                      Y2="1" />
                    </PageSlide.SlideOutEasing>
                </PageSlide>
            </Setter.Value>
        </Setter>
        <Setter Property="ModalTransition">
            <Setter.Value>
                <PageSlide FillMode="Forward"
                           Orientation="Vertical"
                           Duration="0:0:0.25">
                    <PageSlide.SlideInEasing>
                        <SplineEasing X1="0.16"
                                      X2="0.3"
                                      Y1="1"
                                      Y2="1" />
                    </PageSlide.SlideInEasing>
                    <PageSlide.SlideOutEasing>
                        <SplineEasing X1="0.2"
                                      X2="0.3"
                                      Y1="0.85"
                                      Y2="1" />
                    </PageSlide.SlideOutEasing>
                </PageSlide>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <Panel>
                        <DockPanel>
                            <Border Name="PART_NavBarSpacer"
                                    Height="{TemplateBinding EffectiveBarHeight}"
                                    DockPanel.Dock="Top"
                                    IsVisible="False" />

                            <ContentPresenter Name="PART_BottomCommandBar"
                                              HorizontalContentAlignment="Stretch"
                                              Background="{TemplateBinding Background}"
                                              Content="{Binding CurrentPage?.(NavigationPage.BottomCommandBar), RelativeSource={RelativeSource TemplatedParent}, FallbackValue={x:Null}}"
                                              DockPanel.Dock="Bottom" />

                            <Grid Name="PART_ContentHost"
                                  Background="{TemplateBinding Background}"
                                  ClipToBounds="True">
                                <ContentPresenter Name="PART_PageBackPresenter"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch" />
                                <ContentPresenter Name="PART_PagePresenter"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch" />
                            </Grid>
                        </DockPanel>

                        <Border Name="PART_NavigationBar"
                                Height="{TemplateBinding EffectiveBarHeight}"
                                VerticalAlignment="Top"
                                Background="{DynamicResource ThemeControlMidBrush}">
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Button x:Name="PART_BackButton"
                                        Grid.Column="0"
                                        BorderThickness="0"
                                        ButtonAttach.ShowShadow="False"
                                        CornerRadius="0"
                                        IsVisible="{TemplateBinding IsBackButtonEffectivelyVisible}"
                                        Theme="{StaticResource SecondaryButtonTheme}">
                                    <Panel>
                                        <PathIcon x:Name="PART_BackButtonDefaultIcon"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Data="{DynamicResource ArrowLeftGlyph}" />
                                        <ContentPresenter x:Name="PART_BackButtonContentPresenter"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                    </Panel>
                                </Button>

                                <ContentPresenter Name="PART_Header"
                                                  Grid.Column="1"
                                                  Margin="6,0"
                                                  VerticalAlignment="Center"
                                                  Content="{Binding CurrentPage?.Header, RelativeSource={RelativeSource TemplatedParent}, FallbackValue={x:Null}}"
                                                  ContentTemplate="{Binding CurrentPage?.HeaderTemplate, RelativeSource={RelativeSource TemplatedParent}, FallbackValue={x:Null}}"
                                                  FontWeight="SemiBold" />

                                <ContentPresenter Name="PART_TopCommandBar"
                                                  Grid.Column="2"
                                                  HorizontalAlignment="Right"
                                                  Content="{Binding CurrentPage?.(NavigationPage.TopCommandBar), RelativeSource={RelativeSource TemplatedParent}, FallbackValue={x:Null}}" />
                            </Grid>
                        </Border>

                        <Border Name="PART_NavBarShadow"
                                Height="4"
                                VerticalAlignment="Top"
                                IsHitTestVisible="False"
                                IsVisible="False"
                                ZIndex="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Offset="0" Color="#0C000000" />
                                    <GradientStop Offset="1" Color="#00000000" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <ContentPresenter Name="PART_ModalBackPresenter"
                                          Background="{TemplateBinding Background}"
                                          IsVisible="False"
                                          ZIndex="99" />
                        <ContentPresenter Name="PART_ModalPresenter"
                                          Background="{TemplateBinding Background}"
                                          IsVisible="False"
                                          ZIndex="100" />
                    </Panel>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:nav-bar-inset /template/ Border#PART_NavBarSpacer">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <Style Selector="^:nav-bar-compact /template/ ContentPresenter#PART_TopCommandBar CommandBar">
            <Setter Property="DefaultLabelPosition" Value="Collapsed" />
        </Style>
    </ControlTheme>
</ResourceDictionary>