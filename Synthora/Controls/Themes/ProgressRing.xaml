<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    x:ClassModifier="internal"
                    x:CompileBindings="True">

    <Design.PreviewWith>
        <Border Padding="20">
            <StackPanel Spacing="20">
                <ProgressRing />
                <ProgressRing Width="48"
                              Height="48"
                              StrokeThickness="3" />
                <ProgressRing Width="64"
                              Height="64"
                              StrokeThickness="4" />
                <ProgressRing IsActive="False" />
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <ControlTheme x:Key="{x:Type ProgressRing}" TargetType="ProgressRing">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
        <Setter Property="StrokeThickness" Value="2" />

        <Style Selector="^.Secondary">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryBrush}" />
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Opacity" Value="{DynamicResource ThemeDisabledLowOpacity}" />
        </Style>
    </ControlTheme>

</ResourceDictionary>