<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    x:ClassModifier="internal"
                    x:CompileBindings="True">

    <Design.PreviewWith>
        <Border Width="400" Height="400">
            <TabbedPage TabControlAttach.ShowHeaderSeparator="False" TabPlacement="Bottom">
                <ContentPage Header="Home">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="Home page" />
                </ContentPage>
                <ContentPage Header="Favorites">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="Favorites page" />
                </ContentPage>
            </TabbedPage>
        </Border>
    </Design.PreviewWith>

    <SolidColorBrush x:Key="TabbedPageTabItemHeaderBackgroundUnselected" Color="Transparent" />
    <SolidColorBrush x:Key="TabbedPageTabItemHeaderBackgroundSelected" Color="Transparent" />
    <SolidColorBrush x:Key="TabbedPageTabItemHeaderBackgroundUnselectedPointerOver" Color="{DynamicResource ThemeControlMidColor}" />
    <SolidColorBrush x:Key="TabbedPageTabItemHeaderBackgroundSelectedPointerOver" Color="Transparent" />
    <SolidColorBrush x:Key="TabbedPageTabItemHeaderBackgroundUnselectedPressed" Color="{DynamicResource ThemeControlHighlightMidColor}" />
    <SolidColorBrush x:Key="TabbedPageTabItemHeaderBackgroundSelectedPressed" Color="Transparent" />

    <SolidColorBrush x:Key="TabbedPageTabItemHeaderForegroundSelected" Color="{DynamicResource PrimaryColor}" />

    <x:Double x:Key="TabbedPageTabItemHeaderMinHeight">36</x:Double>
    <x:Double x:Key="TabbedPageTabItemHeaderPipeThickness">2</x:Double>
    <BoxShadows x:Key="TabbedPageTabItemHeaderBoxShadow">0 0 6 0 #30000000</BoxShadows>

    <!--  Tab item sizing & shape  -->
    <CornerRadius x:Key="TabbedPageTabItemHeaderCornerRadius">0</CornerRadius>
    <Thickness x:Key="TabbedPageTabItemHeaderMargin">0</Thickness>

    <!--  Icon + text header layout  -->
    <x:Double x:Key="TabbedPageTabItemHeaderIconSize">24</x:Double>
    <x:Double x:Key="TabbedPageTabItemHeaderSpacing">2</x:Double>

    <!--  Tab strip (bar) styling  -->
    <Thickness x:Key="TabbedPageTabStripMargin">0</Thickness>

    <!--  TabbedPage TabControl theme  -->
    <ControlTheme x:Key="TabbedPageTabControlTheme" TargetType="TabControl">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <DockPanel>
                        <Border Name="PART_TabStrip"
                                Margin="{DynamicResource TabbedPageTabStripMargin}"
                                DockPanel.Dock="{TemplateBinding TabStripPlacement}">
                            <ItemsPresenter Name="PART_ItemsPresenter">
                                <ItemsPresenter.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1" />
                                    </ItemsPanelTemplate>
                                </ItemsPresenter.ItemsPanel>
                            </ItemsPresenter>
                        </Border>
                        <Border Name="contentBorder"
                                Margin="{TemplateBinding Padding}"
                                BorderBrush="{DynamicResource ThemeBorderLowBrush}">
                            <Panel>
                                <ContentPresenter Name="PART_SelectedContentHost2"
                                                  HorizontalContentAlignment="Stretch"
                                                  VerticalContentAlignment="Stretch"
                                                  IsVisible="False" />
                                <ContentPresenter Name="PART_SelectedContentHost"
                                                  HorizontalContentAlignment="Stretch"
                                                  VerticalContentAlignment="Stretch" />
                            </Panel>
                        </Border>
                    </DockPanel>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^[TabStripPlacement=Left] /template/ ItemsPresenter#PART_ItemsPresenter &gt; UniformGrid,   ^[TabStripPlacement=Right] /template/ ItemsPresenter#PART_ItemsPresenter &gt; UniformGrid">
            <Setter Property="Rows" Value="0" />
            <Setter Property="Columns" Value="1" />
        </Style>

        <Style Selector="^[TabStripPlacement=Top]">
            <Style Selector="^ /template/ Border#contentBorder">
                <Setter Property="BorderThickness" Value="0,1,0,0" />
            </Style>
        </Style>
        <Style Selector="^[TabStripPlacement=Left]">
            <Style Selector="^ /template/ Border#contentBorder">
                <Setter Property="BorderThickness" Value="1,0,0,0" />
            </Style>
        </Style>
        <Style Selector="^[TabStripPlacement=Right]">
            <Style Selector="^ /template/ Border#contentBorder">
                <Setter Property="BorderThickness" Value="0,0,1,0" />
            </Style>
        </Style>
        <Style Selector="^[TabStripPlacement=Bottom]">
            <Style Selector="^ /template/ Border#contentBorder">
                <Setter Property="BorderThickness" Value="0,0,0,1" />
            </Style>
        </Style>
        <Style Selector="^[(TabControlAttach.ShowHeaderSeparator)=False]">
            <Style Selector="^ /template/ Border#contentBorder">
                <Setter Property="BorderThickness" Value="0" />
            </Style>
            <Style Selector="^ /template/ Border#PART_TabStrip">
                <Setter Property="ZIndex" Value="1" />
                <Setter Property="BoxShadow" Value="{DynamicResource TabbedPageTabItemHeaderBoxShadow}" />
            </Style>
        </Style>
    </ControlTheme>

    <!--  TabbedPage TabItem theme  -->
    <ControlTheme x:Key="TabbedPageTabItemTheme" TargetType="TabItem">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeLarge}" />
        <Setter Property="Background" Value="{DynamicResource TabbedPageTabItemHeaderBackgroundUnselected}" />
        <Setter Property="Padding" Value="{DynamicResource ThemeHeaderControlPadding}" />
        <Setter Property="Margin" Value="{DynamicResource TabbedPageTabItemHeaderMargin}" />
        <Setter Property="MinHeight" Value="{DynamicResource TabbedPageTabItemHeaderMinHeight}" />
        <Setter Property="CornerRadius" Value="{DynamicResource TabbedPageTabItemHeaderCornerRadius}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <ControlTemplate>
                <Panel>
                    <Border Name="PART_LayoutRoot"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <StackPanel Name="PART_HeaderPanel"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Spacing="{DynamicResource TabbedPageTabItemHeaderSpacing}">
                            <ContentPresenter Name="PART_IconPresenter"
                                              Width="{DynamicResource TabbedPageTabItemHeaderIconSize}"
                                              Height="{DynamicResource TabbedPageTabItemHeaderIconSize}"
                                              HorizontalAlignment="Center"
                                              Content="{TemplateBinding Icon}"
                                              ContentTemplate="{TemplateBinding IconTemplate}"
                                              IsVisible="{TemplateBinding Icon,
                                                                          Converter={x:Static ObjectConverters.IsNotNull}}" />
                            <ContentPresenter Name="PART_ContentPresenter"
                                              HorizontalAlignment="Center"
                                              HorizontalContentAlignment="Center"
                                              Content="{TemplateBinding Header}"
                                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                                              RecognizesAccessKey="True" />
                        </StackPanel>
                    </Border>

                    <Border Name="PART_SelectedPipe"
                            Background="{DynamicResource PrimaryBrush}"
                            IsVisible="False" />
                </Panel>
            </ControlTemplate>
        </Setter>

        <!--  Selected state  -->
        <Style Selector="^:selected">
            <Setter Property="Background" Value="{DynamicResource TabbedPageTabItemHeaderBackgroundSelected}" />
            <Setter Property="Foreground" Value="{DynamicResource TabbedPageTabItemHeaderForegroundSelected}" />
        </Style>
        <Style Selector="^:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <!--  Placement-specific pipe positioning  -->
        <Style Selector="^[TabStripPlacement=Top] /template/ Border#PART_SelectedPipe">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Height" Value="{DynamicResource TabbedPageTabItemHeaderPipeThickness}" />
        </Style>
        <Style Selector="^[TabStripPlacement=Bottom] /template/ Border#PART_SelectedPipe">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Height" Value="{DynamicResource TabbedPageTabItemHeaderPipeThickness}" />
        </Style>
        <Style Selector="^[TabStripPlacement=Left] /template/ Border#PART_SelectedPipe">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Width" Value="{DynamicResource TabbedPageTabItemHeaderPipeThickness}" />
        </Style>
        <Style Selector="^[TabStripPlacement=Right] /template/ Border#PART_SelectedPipe">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Width" Value="{DynamicResource TabbedPageTabItemHeaderPipeThickness}" />
        </Style>

        <!--  Pointer-over  -->
        <Style Selector="^:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource TabbedPageTabItemHeaderBackgroundUnselectedPointerOver}" />
        </Style>

        <!--  Selected + pointer-over  -->
        <Style Selector="^:selected:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource TabbedPageTabItemHeaderBackgroundSelectedPointerOver}" />
        </Style>

        <!--  Pressed  -->
        <Style Selector="^:pressed /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource TabbedPageTabItemHeaderBackgroundUnselectedPressed}" />
        </Style>

        <!--  Selected + pressed  -->
        <Style Selector="^:selected:pressed /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="{DynamicResource TabbedPageTabItemHeaderBackgroundSelectedPressed}" />
        </Style>

        <!--  Focus visible  -->
        <Style Selector="^:focus-visible /template/ Border#PART_LayoutRoot">
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderHighBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>

        <!--  Disabled  -->
        <Style Selector="^:disabled">
            <Setter Property="Opacity" Value="{DynamicResource ThemeDisabledHighOpacity}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="SecondaryTabbedPageTabItemTheme"
                  BasedOn="{StaticResource TabbedPageTabItemTheme}"
                  TargetType="TabItem">
        <Style Selector="^:selected">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryBrush}" />
        </Style>
        <Style Selector="^:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="Background" Value="{DynamicResource SecondaryBrush}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type TabbedPage}" TargetType="TabbedPage">
        <!-- <Setter Property="Background" Value="Transparent" /> -->
        <Setter Property="Template">
            <ControlTemplate>
                <TabControl Name="PART_TabControl"
                            Padding="{TemplateBinding Padding}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            ItemContainerTheme="{StaticResource TabbedPageTabItemTheme}"
                            TabControlAttach.ShowHeaderSeparator="{TemplateBinding TabControlAttach.ShowHeaderSeparator}"
                            Theme="{StaticResource TabbedPageTabControlTheme}" />
            </ControlTemplate>
        </Setter>

        <Style Selector="^.Secondary /template/ TabControl#PART_TabControl">
            <Setter Property="ItemContainerTheme" Value="{StaticResource SecondaryTabbedPageTabItemTheme}" />
        </Style>
    </ControlTheme>
</ResourceDictionary>