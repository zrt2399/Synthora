<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    x:ClassModifier="internal"
                    x:CompileBindings="True">

    <ControlTheme x:Key="{x:Type ToggleSplitButton}"
                  BasedOn="{StaticResource {x:Type ToggleSplitButton}}"
                  TargetType="ToggleSplitButton" />

    <ControlTheme x:Key="SuccessToggleSplitButtonTheme"
                  BasedOn="{StaticResource SuccessSplitButtonTheme}"
                  TargetType="ToggleSplitButton" />

    <ControlTheme x:Key="WarningToggleSplitButtonTheme"
                  BasedOn="{StaticResource WarningSplitButtonTheme}"
                  TargetType="ToggleSplitButton" />

    <ControlTheme x:Key="DangerToggleSplitButtonTheme"
                  BasedOn="{StaticResource DangerSplitButtonTheme}"
                  TargetType="ToggleSplitButton" />

    <ControlTheme x:Key="ErrorToggleSplitButtonTheme"
                  BasedOn="{StaticResource ErrorSplitButtonTheme}"
                  TargetType="ToggleSplitButton" />

    <ControlTheme x:Key="TonalToggleSplitButtonTheme"
                  BasedOn="{StaticResource TonalSplitButtonTheme}"
                  TargetType="ToggleSplitButton" />

    <ControlTheme x:Key="SecondaryToggleSplitButtonTheme"
                  BasedOn="{StaticResource SecondarySplitButtonTheme}"
                  TargetType="ToggleSplitButton" />
</ResourceDictionary>