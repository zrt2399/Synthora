<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    x:ClassModifier="internal"
                    x:CompileBindings="True">

    <ControlTheme x:Key="OutlineToggleSplitButtonTheme"
                  BasedOn="{StaticResource OutlineSplitButtonTheme}"
                  TargetType="ToggleSplitButton" />

    <ControlTheme x:Key="{x:Type ToggleSplitButton}"
                  BasedOn="{StaticResource OutlineToggleSplitButtonTheme}"
                  TargetType="ToggleSplitButton" />

    <ControlTheme x:Key="SolidToggleSplitButtonTheme"
                  BasedOn="{StaticResource SolidSplitButtonTheme}"
                  TargetType="ToggleSplitButton" />

</ResourceDictionary>