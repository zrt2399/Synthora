<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="using:Avalonia.Controls.Converters"
                    x:ClassModifier="internal"
                    x:CompileBindings="True">

    <converters:MarginMultiplierConverter x:Key="DropDownButtonMarginMultiplier"
                                          Bottom="True"
                                          Indent="1"
                                          Right="True"
                                          Top="True" />

    <ControlTemplate x:Key="DropDownButtonTemplate" TargetType="DropDownButton">
        <ShadowChrome Name="RootChrome"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      BoxShadow="{DynamicResource EmptyBoxShadow}"
                      CornerRadius="{TemplateBinding CornerRadius}">
            <Grid Name="InnerGrid" ColumnDefinitions="*,Auto">
                <ContentPresenter Name="PART_ContentPresenter"
                                  Margin="{TemplateBinding Padding}"
                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                  Content="{TemplateBinding Content}"
                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                  RecognizesAccessKey="True" />

                <ContentPresenter Name="PART_DropDownContentPresenter"
                                  Grid.Column="1"
                                  Margin="{TemplateBinding Padding,
                                                           Converter={StaticResource DropDownButtonMarginMultiplier}}"
                                  VerticalAlignment="Center"
                                  Content="{TemplateBinding DropDownButtonAttach.DropDownIcon}"
                                  IsVisible="{TemplateBinding DropDownButtonAttach.DropDownIcon,
                                                              Converter={x:Static ObjectConverters.IsNotNull}}">
                    <ContentPresenter.Transitions>
                        <Transitions>
                            <TransformOperationsTransition Easing="CubicEaseInOut"
                                                           Property="RenderTransform"
                                                           Duration="0:0:0.2" />
                        </Transitions>
                    </ContentPresenter.Transitions>
                </ContentPresenter>
            </Grid>
        </ShadowChrome>
    </ControlTemplate>

    <Template x:Key="DropDownButtonIcon">
        <PathIcon Width="12"
                  Height="12"
                  Data="{DynamicResource ArrowDownData}" />
    </Template>

    <ControlTheme x:Key="OutlineDropDownButtonTheme"
                  BasedOn="{StaticResource OutlineButtonTheme}"
                  TargetType="DropDownButton">
        <Setter Property="Template" Value="{StaticResource DropDownButtonTemplate}" />
        <Setter Property="DropDownButtonAttach.DropDownIcon" Value="{StaticResource DropDownButtonIcon}" />
        <Style Selector="^[(DropDownButtonAttach.EnableDropDownIconAnimation)=True]:flyout-open /template/ ContentPresenter#PART_DropDownContentPresenter">
            <Setter Property="RenderTransform" Value="rotate(180deg)" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type DropDownButton}"
                  BasedOn="{StaticResource OutlineDropDownButtonTheme}"
                  TargetType="DropDownButton" />

    <ControlTheme x:Key="SolidDropDownButtonTheme"
                  BasedOn="{StaticResource SolidButtonTheme}"
                  TargetType="DropDownButton">
        <Setter Property="Template" Value="{StaticResource DropDownButtonTemplate}" />
        <Setter Property="DropDownButtonAttach.DropDownIcon" Value="{StaticResource DropDownButtonIcon}" />
        <Style Selector="^[(DropDownButtonAttach.EnableDropDownIconAnimation)=True]:flyout-open /template/ ContentPresenter#PART_DropDownContentPresenter">
            <Setter Property="RenderTransform" Value="rotate(180deg)" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="BorderlessDropDownButtonTheme"
                  BasedOn="{StaticResource BorderlessButtonTheme}"
                  TargetType="DropDownButton">
        <Setter Property="Template" Value="{StaticResource DropDownButtonTemplate}" />
        <Setter Property="DropDownButtonAttach.DropDownIcon" Value="{StaticResource DropDownButtonIcon}" />
        <Style Selector="^[(DropDownButtonAttach.EnableDropDownIconAnimation)=True]:flyout-open /template/ ContentPresenter#PART_DropDownContentPresenter">
            <Setter Property="RenderTransform" Value="rotate(180deg)" />
        </Style>
    </ControlTheme>

</ResourceDictionary>