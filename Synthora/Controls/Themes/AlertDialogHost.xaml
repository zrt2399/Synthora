<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:overlays="clr-namespace:Synthora.Overlays"
                    x:ClassModifier="internal"
                    x:CompileBindings="True">

    <ControlTheme x:Key="{x:Type DialogOverlayPopupHost}" TargetType="DialogOverlayPopupHost">
        <Setter Property="KeyboardNavigation.TabNavigation" Value="Cycle" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <ControlTemplate>
                <ContentPresenter Name="PART_ContentPresenter"
                                  Padding="{TemplateBinding Padding}"
                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                  Background="{TemplateBinding Background}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  Content="{TemplateBinding Content}"
                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                  CornerRadius="{TemplateBinding CornerRadius}" />
            </ControlTemplate>
        </Setter>
        <Style Selector="^[DisableOpeningAnimation=False][IsOpen=True]">
            <Style.Animations>
                <Animation Easing="SineEaseInOut"
                           FillMode="Both"
                           Duration="0:0:0.3">
                    <KeyFrame Cue="0%">
                        <Setter Property="ScaleTransform.ScaleY" Value="0.8" />
                        <Setter Property="ScaleTransform.ScaleX" Value="0.8" />
                        <Setter Property="Opacity" Value="0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="ScaleTransform.ScaleY" Value="1" />
                        <Setter Property="ScaleTransform.ScaleX" Value="1" />
                        <Setter Property="Opacity" Value="1" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type DialogHost}" TargetType="DialogHost">
        <Setter Property="BlurRadius" Value="1" />
        <Setter Property="DialogBoxShadow" Value="{DynamicResource DialogBoxShadow}" />
        <Setter Property="OverlayBackground" Value="Transparent" />
        <Setter Property="HorizontalDialogAlignment" Value="Center" />
        <Setter Property="VerticalDialogAlignment" Value="Center" />
        <Setter Property="PopupTemplate">
            <ControlTemplate>
                <ShadowChrome Name="RootChrome"
                              MinWidth="220"
                              MinHeight="120"
                              Margin="32"
                              Background="{DynamicResource ThemeBackgroundBrush}"
                              BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                              BorderThickness="{DynamicResource ThemeBorderThickness}"
                              BoxShadow="{Binding $parent[DialogHost].DialogBoxShadow}"
                              CornerRadius="{DynamicResource ThemeBorderCornerRadiusLarge}">
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}" />
                </ShadowChrome>
            </ControlTemplate>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        ClipToBounds="{TemplateBinding ClipToBounds}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <Panel>
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}">
                            <ContentPresenter.Effect>
                                <BlurEffect Radius="{Binding BlurRadius, RelativeSource={RelativeSource TemplatedParent}}" />
                            </ContentPresenter.Effect>
                        </ContentPresenter>

                        <ItemsControl Name="DialogHost"
                                      Background="{TemplateBinding OverlayBackground}"
                                      IsVisible="{TemplateBinding IsOpen}"
                                      ItemsSource="{Binding Dialogs, RelativeSource={RelativeSource TemplatedParent}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Panel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </Panel>
                </Border>
            </ControlTemplate>
        </Setter>
        <Style Selector="^ /template/ ItemsControl#DialogHost">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Easing="0.1,0.9,0.2,1.0"
                                      Property="Opacity"
                                      Duration="0:0:0.3" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="^:not(:open)">
            <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Effect" Value="{x:Null}" />
            </Style>
        </Style>

        <Style Selector="^:open">
            <Style Selector="^ /template/ ItemsControl#DialogHost">
                <Setter Property="Opacity" Value="1" />
            </Style>

            <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="KeyboardNavigation.TabNavigation" Value="None" />
                <Setter Property="IsHitTestVisible" Value="False" />
                <Setter Property="IsTabStop" Value="False" />
                <Setter Property="Focusable" Value="False" />
            </Style>
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type AlertDialogHost}"
                  BasedOn="{StaticResource {x:Type DialogHost}}"
                  TargetType="AlertDialogHost">
        <Setter Property="PopupTemplate">
            <ControlTemplate TargetType="DialogOverlayPopupHost">
                <Border Name="DialogBorder"
                        MinWidth="220"
                        MinHeight="160"
                        MaxWidth="{Binding AlertDialogInstance?.MaxWidth, RelativeSource={RelativeSource TemplatedParent}}"
                        MaxHeight="{Binding AlertDialogInstance?.MaxHeight, RelativeSource={RelativeSource TemplatedParent}}"
                        Margin="32"
                        Padding="10"
                        Background="{DynamicResource ThemeBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                        BorderThickness="{DynamicResource ThemeBorderThickness}"
                        BoxShadow="{Binding $parent[AlertDialogHost].DialogBoxShadow}"
                        CornerRadius="{DynamicResource ThemeBorderCornerRadiusLarge}">
                    <Grid RowDefinitions="Auto,*,Auto">
                        <Grid.Styles>
                            <Style Selector="Button">
                                <Setter Property="CornerRadius">
                                    <MultiBinding Converter="{x:Static SynthoraConverters.BorderCornerRadiusConverter}" ConverterParameter="{x:Static CornerRadiusType.All}">
                                        <Binding Path="#DialogBorder.CornerRadius" />
                                        <Binding Path="#DialogBorder.BorderThickness" />
                                        <Binding Path="#DialogBorder.Padding" />
                                        <Binding Path="#ButtonPanel.Margin" />
                                    </MultiBinding>
                                </Setter>
                            </Style>
                            <Style Selector="TextBox">
                                <Setter Property="IsReadOnly" Value="True" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="{x:Null}" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </Grid.Styles>
                        <Panel>
                            <TextBox Name="title"
                                     Margin="2,0,2,10"
                                     HorizontalAlignment="Left"
                                     FontWeight="SemiBold"
                                     IsVisible="{Binding AlertDialogInstance?.Title, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                     Text="{Binding AlertDialogInstance?.Title, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Button HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource ThemeBackgroundBrush}"
                                    Classes="Error"
                                    Command="{Binding AlertDialogInstance?.None, RelativeSource={RelativeSource TemplatedParent}}"
                                    IsVisible="{Binding AlertDialogInstance?.ShowCloseButton, RelativeSource={RelativeSource TemplatedParent}}"
                                    Theme="{StaticResource IconButtonTheme}">
                                <Button.CornerRadius>
                                    <MultiBinding Converter="{x:Static SynthoraConverters.BorderCornerRadiusConverter}" ConverterParameter="{x:Static CornerRadiusType.All}">
                                        <Binding Path="#DialogBorder.CornerRadius" />
                                        <Binding Path="#DialogBorder.BorderThickness" />
                                        <Binding Path="#DialogBorder.Padding" />
                                    </MultiBinding>
                                </Button.CornerRadius>
                                <PathIcon Width="12"
                                          Height="12"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" />
                            </Button>
                        </Panel>

                        <DockPanel Grid.Row="1">
                            <TipIcon Name="icon"
                                     Width="32"
                                     Height="32"
                                     Margin="10"
                                     VerticalAlignment="Top"
                                     DockPanel.Dock="Left"
                                     IconType="{Binding AlertDialogInstance?.IconType, RelativeSource={RelativeSource TemplatedParent}}"
                                     IsVisible="{Binding AlertDialogInstance?.IconType, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static ObjectConverters.NotEqual}, ConverterParameter={x:Static IconType.None}}" />

                            <TextBox Name="message"
                                     Margin="10"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Top"
                                     Text="{Binding AlertDialogInstance?.Message, RelativeSource={RelativeSource TemplatedParent}}"
                                     TextWrapping="Wrap" />
                        </DockPanel>

                        <UniformGrid x:Name="ButtonPanel"
                                     Grid.Row="2"
                                     Margin="10"
                                     HorizontalAlignment="Right"
                                     Classes.FooterStretched="{Binding AlertDialogInstance?.IsFooterStretched, RelativeSource={RelativeSource TemplatedParent}}"
                                     ColumnSpacing="10"
                                     FocusAttach.IsFocused="True"
                                     IsVisible="{Binding AlertDialogInstance?.DialogButton, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static ObjectConverters.NotEqual}, ConverterParameter={x:Static overlays:DialogButton.None}}"
                                     Rows="1">
                            <UniformGrid.Styles>
                                <Style Selector="UniformGrid.FooterStretched">
                                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                                </Style>
                                <Style Selector="Button">
                                    <Setter Property="MinWidth" Value="80" />
                                </Style>
                            </UniformGrid.Styles>
                            <Button Name="OKButton"
                                    Classes="Primary"
                                    Command="{Binding AlertDialogInstance?.OK, RelativeSource={RelativeSource TemplatedParent}}"
                                    Content="{DynamicResource StringAlertDialogButtonOK}"
                                    IsDefault="True"
                                    IsVisible="{Binding AlertDialogInstance?.DialogButton, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static SynthoraConverters.HasFlag}, ConverterParameter={x:Static overlays:DialogButton.OK}}"
                                    Theme="{StaticResource SolidButtonTheme}" />
                            <Button Name="YesButton"
                                    Classes="Primary"
                                    Command="{Binding AlertDialogInstance?.Yes, RelativeSource={RelativeSource TemplatedParent}}"
                                    Content="{DynamicResource StringAlertDialogButtonYes}"
                                    IsDefault="True"
                                    IsVisible="{Binding AlertDialogInstance?.DialogButton, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static SynthoraConverters.HasFlag}, ConverterParameter={x:Static overlays:DialogButton.Yes}}"
                                    Theme="{StaticResource SolidButtonTheme}" />
                            <Button Name="NoButton"
                                    Command="{Binding AlertDialogInstance?.No, RelativeSource={RelativeSource TemplatedParent}}"
                                    Content="{DynamicResource StringAlertDialogButtonNo}"
                                    IsVisible="{Binding AlertDialogInstance?.DialogButton, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static SynthoraConverters.HasFlag}, ConverterParameter={x:Static overlays:DialogButton.No}}" />
                            <Button Name="CancelButton"
                                    Command="{Binding AlertDialogInstance?.Cancel, RelativeSource={RelativeSource TemplatedParent}}"
                                    Content="{DynamicResource StringAlertDialogButtonCancel}"
                                    IsCancel="True"
                                    IsVisible="{Binding AlertDialogInstance?.DialogButton, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static SynthoraConverters.HasFlag}, ConverterParameter={x:Static overlays:DialogButton.Cancel}}" />
                            <Button Name="AbortButton"
                                    Classes="Error"
                                    Command="{Binding AlertDialogInstance?.Abort, RelativeSource={RelativeSource TemplatedParent}}"
                                    Content="{DynamicResource StringAlertDialogButtonAbort}"
                                    IsVisible="{Binding AlertDialogInstance?.DialogButton, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static SynthoraConverters.HasFlag}, ConverterParameter={x:Static overlays:DialogButton.Abort}}"
                                    Theme="{StaticResource SolidButtonTheme}" />
                        </UniformGrid>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

</ResourceDictionary>