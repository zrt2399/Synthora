<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    x:ClassModifier="internal"
                    x:CompileBindings="True">

    <ControlTheme x:Key="{x:Type TabControl}" TargetType="TabControl">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="PART_LayoutRoot"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <DockPanel>
                        <ItemsPresenter Name="PART_ItemsPresenter"
                                        HorizontalAlignment="{TemplateBinding TabControlAttach.HorizontalHeaderAlignment}"
                                        VerticalAlignment="{TemplateBinding TabControlAttach.VerticalHeaderAlignment}"
                                        DockPanel.Dock="{TemplateBinding TabStripPlacement}"
                                        ItemsPanel="{TemplateBinding ItemsPanel}" />
                        <Border Name="contentBorder" BorderBrush="{DynamicResource ThemeBorderLowBrush}">
                            <Panel Margin="{TemplateBinding Padding}">
                                <ContentPresenter Name="PART_SelectedContentHost2"
                                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  IsVisible="False" />
                                <ContentPresenter Name="PART_SelectedContentHost"
                                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Panel>
                        </Border>
                    </DockPanel>
                </Border>
            </ControlTemplate>
        </Setter>
        <Style Selector="^[TabStripPlacement=Top]">
            <Style Selector="^ /template/ Border#contentBorder">
                <Setter Property="BorderThickness" Value="0,1,0,0" />
            </Style>
        </Style>

        <Style Selector="^[TabStripPlacement=Left]">
            <Style Selector="^ /template/ Border#contentBorder">
                <Setter Property="BorderThickness" Value="1,0,0,0" />
            </Style>
            <Style Selector="^ /template/ ItemsPresenter#PART_ItemsPresenter &gt; WrapPanel">
                <Setter Property="Orientation" Value="Vertical" />
            </Style>
        </Style>

        <Style Selector="^[TabStripPlacement=Right]">
            <Style Selector="^ /template/ Border#contentBorder">
                <Setter Property="BorderThickness" Value="0,0,1,0" />
            </Style>
            <Style Selector="^ /template/ ItemsPresenter#PART_ItemsPresenter &gt; WrapPanel">
                <Setter Property="Orientation" Value="Vertical" />
            </Style>
        </Style>

        <Style Selector="^[TabStripPlacement=Bottom]">
            <Style Selector="^ /template/ Border#contentBorder">
                <Setter Property="BorderThickness" Value="0,0,0,1" />
            </Style>
        </Style>

        <Style Selector="^[(TabControlAttach.ShowHeaderSeparator)=False] /template/ Border#contentBorder">
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="SegmentedTabControlTheme" TargetType="TabControl">
        <Setter Property="ItemContainerTheme" Value="{DynamicResource SegmentedTabItemTheme}" />
        <Setter Property="ItemsPanel">
            <ItemsPanelTemplate>
                <WrapPanel ItemSpacing="{DynamicResource ThemeControlBorderPaddingDouble}"
                           LineSpacing="{DynamicResource ThemeControlBorderPaddingDouble}"
                           Orientation="Horizontal" />
            </ItemsPanelTemplate>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="PART_LayoutRoot"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <DockPanel>
                        <Border Name="HeaderRoot"
                                Margin="{DynamicResource ThemeControlBorderPadding}"
                                Padding="{DynamicResource ThemeControlBorderPadding}"
                                HorizontalAlignment="{TemplateBinding TabControlAttach.HorizontalHeaderAlignment}"
                                VerticalAlignment="{TemplateBinding TabControlAttach.VerticalHeaderAlignment}"
                                Background="{DynamicResource SynthoraMidBrush}"
                                CornerRadius="{DynamicResource ThemeBorderCornerRadiusLarge}"
                                DockPanel.Dock="{TemplateBinding TabStripPlacement}">
                            <ItemsPresenter Name="PART_ItemsPresenter" ItemsPanel="{TemplateBinding ItemsPanel}" />
                        </Border>

                        <Border Name="contentBorder" BorderBrush="{DynamicResource ThemeBorderLowBrush}">
                            <Panel Margin="{TemplateBinding Padding}">
                                <ContentPresenter Name="PART_SelectedContentHost2"
                                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  IsVisible="False" />
                                <ContentPresenter Name="PART_SelectedContentHost"
                                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Panel>
                        </Border>
                    </DockPanel>
                </Border>
            </ControlTemplate>
        </Setter>
        <Style Selector="^[TabStripPlacement=Top]">
            <Style Selector="^ /template/ Border#contentBorder">
                <Setter Property="BorderThickness" Value="0,1,0,0" />
            </Style>
        </Style>

        <Style Selector="^[TabStripPlacement=Left]">
            <Style Selector="^ /template/ Border#contentBorder">
                <Setter Property="BorderThickness" Value="1,0,0,0" />
            </Style>
            <Style Selector="^ /template/ ItemsPresenter#PART_ItemsPresenter &gt; WrapPanel">
                <Setter Property="Orientation" Value="Vertical" />
            </Style>
        </Style>

        <Style Selector="^[TabStripPlacement=Right]">
            <Style Selector="^ /template/ Border#contentBorder">
                <Setter Property="BorderThickness" Value="0,0,1,0" />
            </Style>
            <Style Selector="^ /template/ ItemsPresenter#PART_ItemsPresenter &gt; WrapPanel">
                <Setter Property="Orientation" Value="Vertical" />
            </Style>
        </Style>

        <Style Selector="^[TabStripPlacement=Bottom]">
            <Style Selector="^ /template/ Border#contentBorder">
                <Setter Property="BorderThickness" Value="0,0,0,1" />
            </Style>
        </Style>

        <Style Selector="^[(TabControlAttach.ShowHeaderSeparator)=False] /template/ Border#contentBorder">
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style Selector="^.Uniform">
            <Setter Property="ItemsPanel">
                <ItemsPanelTemplate>
                    <UniformGrid ColumnSpacing="{DynamicResource ThemeControlBorderPaddingDouble}" RowSpacing="{DynamicResource ThemeControlBorderPaddingDouble}" />
                </ItemsPanelTemplate>
            </Setter>
            <Style Selector="^[TabStripPlacement=Top], ^[TabStripPlacement=Bottom]">
                <Setter Property="TabControlAttach.HorizontalHeaderAlignment" Value="Stretch" />
                <Style Selector="^ /template/ ItemsPresenter#PART_ItemsPresenter &gt; UniformGrid">
                    <Setter Property="Rows" Value="1" />
                </Style>
            </Style>
            <Style Selector="^[TabStripPlacement=Left], ^[TabStripPlacement=Right]">
                <Setter Property="TabControlAttach.VerticalHeaderAlignment" Value="Stretch" />
                <Style Selector="^ /template/ ItemsPresenter#PART_ItemsPresenter &gt; UniformGrid">
                    <Setter Property="Columns" Value="1" />
                </Style>
            </Style>
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="CardTabControlTheme" TargetType="TabControl">
        <Setter Property="TabControlAttach.ShowHeaderSeparator" Value="False" />
        <Setter Property="ItemContainerTheme" Value="{DynamicResource CardTabItemTheme}" />
        <Setter Property="ItemsPanel">
            <ItemsPanelTemplate>
                <WrapPanel Margin="{DynamicResource ThemeControlBorderPadding}"
                           ItemSpacing="{DynamicResource ThemeControlBorderPaddingDouble}"
                           LineSpacing="{DynamicResource ThemeControlBorderPaddingDouble}"
                           Orientation="Horizontal" />
            </ItemsPanelTemplate>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="PART_LayoutRoot"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <DockPanel>
                        <Border Name="HeaderRoot"
                                HorizontalAlignment="{TemplateBinding TabControlAttach.HorizontalHeaderAlignment}"
                                VerticalAlignment="{TemplateBinding TabControlAttach.VerticalHeaderAlignment}"
                                DockPanel.Dock="{TemplateBinding TabStripPlacement}">
                            <ItemsPresenter Name="PART_ItemsPresenter" ItemsPanel="{TemplateBinding ItemsPanel}" />
                        </Border>

                        <Border Name="contentBorder" BorderBrush="{DynamicResource ThemeBorderLowBrush}">
                            <Panel Margin="{TemplateBinding Padding}">
                                <ContentPresenter Name="PART_SelectedContentHost2"
                                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  IsVisible="False" />
                                <ContentPresenter Name="PART_SelectedContentHost"
                                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Panel>
                        </Border>
                    </DockPanel>
                </Border>
            </ControlTemplate>
        </Setter>
        <Style Selector="^[TabStripPlacement=Top]">
            <Style Selector="^ /template/ Border#contentBorder">
                <Setter Property="BorderThickness" Value="0,1,0,0" />
            </Style>
        </Style>

        <Style Selector="^[TabStripPlacement=Left]">
            <Style Selector="^ /template/ Border#contentBorder">
                <Setter Property="BorderThickness" Value="1,0,0,0" />
            </Style>
            <Style Selector="^ /template/ ItemsPresenter#PART_ItemsPresenter &gt; WrapPanel">
                <Setter Property="Orientation" Value="Vertical" />
            </Style>
        </Style>

        <Style Selector="^[TabStripPlacement=Right]">
            <Style Selector="^ /template/ Border#contentBorder">
                <Setter Property="BorderThickness" Value="0,0,1,0" />
            </Style>
            <Style Selector="^ /template/ ItemsPresenter#PART_ItemsPresenter &gt; WrapPanel">
                <Setter Property="Orientation" Value="Vertical" />
            </Style>
        </Style>

        <Style Selector="^[TabStripPlacement=Bottom]">
            <Style Selector="^ /template/ Border#contentBorder">
                <Setter Property="BorderThickness" Value="0,0,0,1" />
            </Style>
        </Style>

        <Style Selector="^[(TabControlAttach.ShowHeaderSeparator)=False] /template/ Border#contentBorder">
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </ControlTheme>
</ResourceDictionary>