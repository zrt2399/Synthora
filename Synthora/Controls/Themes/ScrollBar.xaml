<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    x:ClassModifier="internal"
                    x:CompileBindings="True">

    <MenuFlyout x:Key="SimpleScrollBarVerticalContextFlyout">
        <MenuItem Command="{x:Static ScrollBarUtils.ScrollToHomeCommand}"
                  CommandParameter="{Binding $parent[ScrollBar]}"
                  Header="{DynamicResource StringScrollBarScrollToTop}" />
        <MenuItem Command="{x:Static ScrollBarUtils.ScrollToEndCommand}"
                  CommandParameter="{Binding $parent[ScrollBar]}"
                  Header="{DynamicResource StringScrollBarScrollToBottom}" />
        <Separator />
        <MenuItem Command="{x:Static ScrollBarUtils.LargeDecrementCommand}"
                  CommandParameter="{Binding $parent[ScrollBar]}"
                  Header="{DynamicResource StringScrollBarPageUp}" />
        <MenuItem Command="{x:Static ScrollBarUtils.LargeIncrementCommand}"
                  CommandParameter="{Binding $parent[ScrollBar]}"
                  Header="{DynamicResource StringScrollBarPageDown}" />
        <Separator />
        <MenuItem Command="{x:Static ScrollBarUtils.SmallDecrementCommand}"
                  CommandParameter="{Binding $parent[ScrollBar]}"
                  Header="{DynamicResource StringScrollBarLineUp}" />
        <MenuItem Command="{x:Static ScrollBarUtils.SmallIncrementCommand}"
                  CommandParameter="{Binding $parent[ScrollBar]}"
                  Header="{DynamicResource StringScrollBarLineDown}" />
    </MenuFlyout>

    <MenuFlyout x:Key="SimpleScrollBarHorizontalContextFlyout">
        <MenuItem Command="{x:Static ScrollBarUtils.ScrollToHomeCommand}"
                  CommandParameter="{Binding $parent[ScrollBar]}"
                  Header="{DynamicResource StringScrollBarScrollToLeftEdge}" />
        <MenuItem Command="{x:Static ScrollBarUtils.ScrollToEndCommand}"
                  CommandParameter="{Binding $parent[ScrollBar]}"
                  Header="{DynamicResource StringScrollBarScrollToRightEdge}" />
        <Separator />
        <MenuItem Command="{x:Static ScrollBarUtils.LargeDecrementCommand}"
                  CommandParameter="{Binding $parent[ScrollBar]}"
                  Header="{DynamicResource StringScrollBarPageLeft}" />
        <MenuItem Command="{x:Static ScrollBarUtils.LargeIncrementCommand}"
                  CommandParameter="{Binding $parent[ScrollBar]}"
                  Header="{DynamicResource StringScrollBarPageRight}" />
        <Separator />
        <MenuItem Command="{x:Static ScrollBarUtils.SmallDecrementCommand}"
                  CommandParameter="{Binding $parent[ScrollBar]}"
                  Header="{DynamicResource StringScrollBarLineLeft}" />
        <MenuItem Command="{x:Static ScrollBarUtils.SmallIncrementCommand}"
                  CommandParameter="{Binding $parent[ScrollBar]}"
                  Header="{DynamicResource StringScrollBarLineRight}" />
    </MenuFlyout>

    <StreamGeometry x:Key="ScrollBarLeftGlyph">
        M16,7 v10 a0.5,0.5 0 0 1 -0.78,0.41 l-7.6,-5.06 a0.5,0.5 0 0 1 0,-0.83 l7.6,-5.07 a0.5,0.5 0 0 1 0.78,0.42 Z
    </StreamGeometry>
    <StreamGeometry x:Key="ScrollBarRightGlyph">
        M8,17 v-10 a0.5,0.5 0 0 1 0.78,-0.41 l7.6,5.06 a0.5,0.5 0 0 1 0,0.83 l-7.6,5.07 a0.5,0.5 0 0 1 -0.78,-0.42 Z
    </StreamGeometry>
    <StreamGeometry x:Key="ScrollBarDownGlyph">
        M7,8 h10 a0.5,0.5 0 0 1 0.41,0.78 l-5.06,7.6 a0.5,0.5 0 0 1 -0.83,0 l-5.07,-7.6 a0.5,0.5 0 0 1 0.41,-0.78 Z
    </StreamGeometry>
    <StreamGeometry x:Key="ScrollBarUpGlyph">
        M17,16 h-10 a0.5,0.5 0 0 1 -0.41,-0.78 l5.06,-7.6 a0.5,0.5 0 0 1 0.83,0 l5.07,7.6 a0.5,0.5 0 0 1 -0.42,0.78 Z
    </StreamGeometry>

    <ControlTheme x:Key="ScrollBarRepeatButtonPathIconTheme" TargetType="PathIcon">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="UseLayoutRounding" Value="False" />
        <Setter Property="Template">
            <ControlTemplate TargetType="PathIcon">
                <Border Background="{TemplateBinding Background}">
                    <Viewbox Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                        <Path Name="PART_Path"
                              Width="24"
                              Height="24"
                              Margin="{TemplateBinding Padding}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="{TemplateBinding Data}"
                              Fill="{TemplateBinding Foreground}" />
                    </Viewbox>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme x:Key="ScrollBarRepeatButtonTheme" TargetType="{x:Type RepeatButton}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <ContentPresenter Name="PART_ContentPresenter"
                                  Padding="{TemplateBinding Padding}"
                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                  Background="{TemplateBinding Background}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  Content="{TemplateBinding Content}"
                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                  CornerRadius="{TemplateBinding CornerRadius}" />
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type ScrollBar}" TargetType="ScrollBar">
        <Setter Property="Cursor" Value="{x:Null}" />
        <Setter Property="ShowDelay" Value="0" />
        <Setter Property="Background" Value="Transparent" />

        <Style Selector="^:vertical">
            <Setter Property="ContextFlyout" Value="{StaticResource SimpleScrollBarVerticalContextFlyout}" />
            <Setter Property="Width" Value="{DynamicResource ScrollBarThickness}" />
            <Setter Property="Template">
                <ControlTemplate TargetType="ScrollBar">
                    <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
                        <Grid RowDefinitions="Auto,*,Auto">
                            <RepeatButton Name="PART_LineUpButton"
                                          Grid.Row="0"
                                          Height="10"
                                          AutomationProperties.Name="Line up"
                                          Theme="{StaticResource ScrollBarRepeatButtonTheme}">
                                <PathIcon Data="{DynamicResource ScrollBarUpGlyph}" Theme="{StaticResource ScrollBarRepeatButtonPathIconTheme}" />
                            </RepeatButton>
                            <Track Grid.Row="1"
                                   DeferThumbDrag="{TemplateBinding ScrollViewer.IsDeferredScrollingEnabled}"
                                   IsDirectionReversed="True"
                                   Maximum="{TemplateBinding Maximum}"
                                   Minimum="{TemplateBinding Minimum}"
                                   Orientation="{TemplateBinding Orientation}"
                                   ViewportSize="{TemplateBinding ViewportSize}"
                                   Value="{TemplateBinding Value,
                                                           Mode=TwoWay}">
                                <Track.DecreaseButton>
                                    <RepeatButton Name="PART_PageUpButton"
                                                  AutomationProperties.Name="Page up"
                                                  Theme="{StaticResource ScrollBarRepeatButtonTheme}" />
                                </Track.DecreaseButton>
                                <Track.IncreaseButton>
                                    <RepeatButton Name="PART_PageDownButton"
                                                  AutomationProperties.Name="Page down"
                                                  Theme="{StaticResource ScrollBarRepeatButtonTheme}" />
                                </Track.IncreaseButton>
                                <Thumb Name="thumb"
                                       Width="{DynamicResource ScrollBarThickness}"
                                       MinHeight="{DynamicResource ScrollBarMinLength}"
                                       AutomationProperties.Name="Position" />
                            </Track>
                            <RepeatButton Name="PART_LineDownButton"
                                          Grid.Row="2"
                                          Height="10"
                                          AutomationProperties.Name="Line down"
                                          Theme="{StaticResource ScrollBarRepeatButtonTheme}">
                                <PathIcon Data="{DynamicResource ScrollBarDownGlyph}" Theme="{StaticResource ScrollBarRepeatButtonPathIconTheme}" />
                            </RepeatButton>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="^:horizontal">
            <Setter Property="Height" Value="{DynamicResource ScrollBarThickness}" />
            <Setter Property="ContextFlyout" Value="{StaticResource SimpleScrollBarHorizontalContextFlyout}" />
            <Setter Property="Template">
                <ControlTemplate TargetType="ScrollBar">
                    <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
                        <Grid Name="PART_RootGrid" ColumnDefinitions="Auto,*,Auto">
                            <RepeatButton Name="PART_LineUpButton"
                                          Grid.Column="0"
                                          Width="10"
                                          AutomationProperties.Name="Column left"
                                          Theme="{StaticResource ScrollBarRepeatButtonTheme}">
                                <PathIcon Data="{DynamicResource ScrollBarLeftGlyph}" Theme="{StaticResource ScrollBarRepeatButtonPathIconTheme}" />
                            </RepeatButton>
                            <Track Grid.Column="1"
                                   DeferThumbDrag="{TemplateBinding ScrollViewer.IsDeferredScrollingEnabled}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Minimum="{TemplateBinding Minimum}"
                                   Orientation="{TemplateBinding Orientation}"
                                   ViewportSize="{TemplateBinding ViewportSize}"
                                   Value="{TemplateBinding Value,
                                                           Mode=TwoWay}">
                                <Track.DecreaseButton>
                                    <RepeatButton Name="PART_PageUpButton"
                                                  AutomationProperties.Name="Page left"
                                                  Theme="{StaticResource ScrollBarRepeatButtonTheme}" />
                                </Track.DecreaseButton>
                                <Track.IncreaseButton>
                                    <RepeatButton Name="PART_PageDownButton"
                                                  AutomationProperties.Name="Page right"
                                                  Theme="{StaticResource ScrollBarRepeatButtonTheme}" />
                                </Track.IncreaseButton>
                                <Thumb Name="thumb"
                                       Height="{DynamicResource ScrollBarThickness}"
                                       MinWidth="{DynamicResource ScrollBarMinLength}"
                                       AutomationProperties.Name="Position" />
                            </Track>
                            <RepeatButton Name="PART_LineDownButton"
                                          Grid.Column="2"
                                          Width="10"
                                          AutomationProperties.Name="Column right"
                                          Theme="{StaticResource ScrollBarRepeatButtonTheme}">
                                <PathIcon Data="{DynamicResource ScrollBarRightGlyph}" Theme="{StaticResource ScrollBarRepeatButtonPathIconTheme}" />
                            </RepeatButton>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="^ /template/ Thumb#thumb">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.1" />
                    <DoubleTransition Property="Height" Duration="0:0:0.1" />
                </Transitions>
            </Setter>
            <Setter Property="Foreground" Value="{DynamicResource ScrollBarThumbBrush}" />
            <Setter Property="CornerRadius" Value="{DynamicResource ThemeBorderCornerRadiusNormal}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Foreground}" CornerRadius="{TemplateBinding CornerRadius}" />
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="^ /template/ Thumb#thumb:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource ScrollBarThumbPointerOverBrush}" />
        </Style>
        <Style Selector="^ /template/ Thumb#thumb:pressed">
            <Setter Property="Foreground" Value="{DynamicResource ScrollBarThumbPressedBrush}" />
        </Style>

        <Style Selector="^ /template/ RepeatButton">
            <Setter Property="Foreground" Value="{DynamicResource ScrollBarThumbBrush}" />
        </Style>
        <Style Selector="^ /template/ RepeatButton:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource ScrollBarThumbPointerOverBrush}" />
        </Style>
        <Style Selector="^ /template/ RepeatButton:pressed">
            <Setter Property="Foreground" Value="{DynamicResource ScrollBarThumbPressedBrush}" />
        </Style>

        <Style Selector="^[IsExpanded=False]">
            <Style Selector="^ /template/ RepeatButton">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="^:vertical /template/ Thumb#thumb">
                <Setter Property="Width" Value="2" />
                <Setter Property="Margin" Value="1" />
                <Setter Property="HorizontalAlignment" Value="Right" />
            </Style>
            <Style Selector="^:horizontal /template/ Thumb#thumb">
                <Setter Property="Height" Value="2" />
                <Setter Property="Margin" Value="1" />
                <Setter Property="VerticalAlignment" Value="Bottom" />
            </Style>
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Opacity" Value="{DynamicResource ThemeDisabledLowOpacity}" />
        </Style>
    </ControlTheme>
</ResourceDictionary>