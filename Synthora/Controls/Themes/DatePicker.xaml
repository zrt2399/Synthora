<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="using:System"
                    x:ClassModifier="internal"
                    x:CompileBindings="True">

    <Design.PreviewWith>
        <Border Width="400" Padding="20">
            <StackPanel VerticalAlignment="Center" Spacing="20">
                <DatePicker />
                <DatePicker CornerRadius="10" />
                <DatePicker IsEnabled="False" />
                <DatePicker>
                    <DataValidationErrors.Error>
                        <sys:Exception>
                            <x:Arguments>
                                <x:String>Error</x:String>
                            </x:Arguments>
                        </sys:Exception>
                    </DataValidationErrors.Error>
                </DatePicker>
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <x:Double x:Key="DatePickerFlyoutPresenterAcceptDismissHostGridHeight">32</x:Double>

    <x:Double x:Key="DatePickerSpacerThemeThickness">1</x:Double>
    <x:Double x:Key="DatePickerPresenterThemeMaxHeight">400</x:Double>

    <ControlTheme x:Key="SimpleDatePickerFlyoutButtonTheme" TargetType="Button">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ContentPresenter Name="PART_ContentPresenter"
                                      HorizontalContentAlignment="Stretch"
                                      VerticalContentAlignment="Stretch"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}" />
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover,^:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderHighlightBrush}" />
        </Style>

        <Style Selector="^:pressed">
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderHighlightPressedBrush}" />
        </Style>

        <Style Selector="^:error">
            <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Opacity" Value="{DynamicResource ThemeDisabledLowOpacity}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type DatePicker}" TargetType="DatePicker">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource SynthoraBorderBrush}" />
        <Setter Property="CornerRadius" Value="{DynamicResource ThemeBorderCornerRadiusSmall}" />
        <Setter Property="BorderThickness" Value="{DynamicResource ThemeBorderThickness}" />
        <Setter Property="Padding" Value="{DynamicResource ThemeControlPadding}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Panel Name="LayoutRoot">
                    <DataValidationErrors>
                        <DockPanel>
                            <HeaderPresenter />

                            <Button Name="PART_FlyoutButton"
                                    Width="{TemplateBinding TextBoxAttach.Width}"
                                    MinWidth="{TemplateBinding TextBoxAttach.MinWidth}"
                                    MaxWidth="{TemplateBinding TextBoxAttach.MaxWidth}"
                                    Padding="0"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    DataValidationErrors.Errors="{TemplateBinding DataValidationErrors.Errors}"
                                    IsEnabled="{TemplateBinding IsEnabled}"
                                    TemplatedControl.IsTemplateFocusTarget="True"
                                    Theme="{StaticResource SimpleDatePickerFlyoutButtonTheme}">
                                <Grid Name="PART_ButtonContentGrid" ColumnDefinitions="78*,Auto,78*,Auto,78*">
                                    <!--  Ignore col defs here, set in code  -->
                                    <TextBlock Name="PART_YearTextBlock"
                                               Margin="{TemplateBinding Padding}"
                                               HorizontalAlignment="Center"
                                               Text="{DynamicResource StringDatePickerYearText}" />
                                    <TextBlock Name="PART_MonthTextBlock"
                                               Grid.Column="2"
                                               Margin="{TemplateBinding Padding}"
                                               HorizontalAlignment="Center"
                                               Text="{DynamicResource StringDatePickerMonthText}" />
                                    <TextBlock Name="PART_DayTextBlock"
                                               Grid.Column="4"
                                               Margin="{TemplateBinding Padding}"
                                               HorizontalAlignment="Center"
                                               Text="{DynamicResource StringDatePickerDayText}" />

                                    <Rectangle x:Name="PART_FirstSpacer"
                                               Grid.Column="1"
                                               Width="1"
                                               HorizontalAlignment="Center"
                                               Fill="{Binding #PART_FlyoutButton.BorderBrush}" />
                                    <Rectangle x:Name="PART_SecondSpacer"
                                               Grid.Column="3"
                                               Width="1"
                                               HorizontalAlignment="Center"
                                               Fill="{Binding #PART_FlyoutButton.BorderBrush}" />
                                </Grid>
                            </Button>
                        </DockPanel>
                    </DataValidationErrors>
                    <Popup Name="PART_Popup"
                           IsLightDismissEnabled="True"
                           IsOpen="{TemplateBinding (DateTimePickerAttach.IsDropDownOpen),
                                                    Mode=TwoWay}"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=PART_FlyoutButton}"
                           WindowManagerAddShadowHint="False">
                        <!--  ScrollViewerAttach.IsDisabled="True" fix mouse scrolling triggers parent  -->
                        <Panel Margin="{Binding #BorderRoot.Margin, Converter={x:Static DateTimePickerPopupMarginConverter.Instance}}" ScrollViewerAttach.IsDisabled="True">
                            <SystemShadowChrome Name="BorderRoot"
                                                Width="{Binding Bounds.Width, RelativeSource={RelativeSource TemplatedParent}}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                <DatePickerPresenter Name="PART_PickerPresenter" />
                            </SystemShadowChrome>
                        </Panel>
                    </Popup>
                </Panel>
            </ControlTemplate>
        </Setter>

        <Style Selector="^[(DateTimePickerAttach.IsDropDownOpen)=True]">
            <Setter Property="BorderBrush" Value="{DynamicResource SynthoraBorderBrush}" />
        </Style>

        <!--  Changes foreground for placeholder text when SelectedDate is null  -->
        <Style Selector="^:hasnodate /template/ Button#PART_FlyoutButton TextBlock">
            <Setter Property="Opacity" Value="{DynamicResource ThemePlaceholderTextOpacity}" />
        </Style>
        <Style Selector="^:disabled /template/ HeaderPresenter">
            <Setter Property="Opacity" Value="{DynamicResource ThemeDisabledLowOpacity}" />
        </Style>
    </ControlTheme>

    <!--  WinUI: DatePickerFlyoutPresenter  -->
    <ControlTheme x:Key="{x:Type DatePickerPresenter}" TargetType="DatePickerPresenter">
        <Setter Property="MaxHeight" Value="{DynamicResource DatePickerPresenterThemeMaxHeight}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid Name="ContentRoot" RowDefinitions="*,Auto">
                    <Grid Name="PART_PickerContainer">
                        <Grid.Styles>
                            <Style Selector="DateTimePickerPanel &gt; ListBoxItem">
                                <Setter Property="Theme" Value="{StaticResource SimpleDateTimePickerItem}" />
                            </Style>
                        </Grid.Styles>
                        <!--  Column Definitions set in code, ignore here  -->
                        <Panel Name="PART_MonthHost">
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden">
                                <DateTimePickerPanel Name="PART_MonthSelector"
                                                     ItemHeight="{DynamicResource DatePickerFlyoutPresenterAcceptDismissHostGridHeight}"
                                                     PanelType="Month"
                                                     ShouldLoop="True" />
                            </ScrollViewer>
                            <RepeatButton Name="PART_MonthUpButton" Theme="{StaticResource SimpleDateTimePickerUpButtonTheme}" />
                            <RepeatButton Name="PART_MonthDownButton" Theme="{StaticResource SimpleDateTimePickerDownButtonTheme}" />
                        </Panel>

                        <Panel Name="PART_DayHost">
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden">
                                <DateTimePickerPanel Name="PART_DaySelector"
                                                     ItemHeight="{DynamicResource DatePickerFlyoutPresenterAcceptDismissHostGridHeight}"
                                                     PanelType="Day"
                                                     ShouldLoop="True" />
                            </ScrollViewer>
                            <RepeatButton Name="PART_DayUpButton" Theme="{StaticResource SimpleDateTimePickerUpButtonTheme}" />
                            <RepeatButton Name="PART_DayDownButton" Theme="{StaticResource SimpleDateTimePickerDownButtonTheme}" />
                        </Panel>

                        <Panel Name="PART_YearHost">
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden">
                                <DateTimePickerPanel Name="PART_YearSelector"
                                                     ItemHeight="{DynamicResource DatePickerFlyoutPresenterAcceptDismissHostGridHeight}"
                                                     PanelType="Year"
                                                     ShouldLoop="False" />
                            </ScrollViewer>
                            <RepeatButton Name="PART_YearUpButton" Theme="{StaticResource SimpleDateTimePickerUpButtonTheme}" />
                            <RepeatButton Name="PART_YearDownButton" Theme="{StaticResource SimpleDateTimePickerDownButtonTheme}" />
                        </Panel>

                        <Rectangle Name="PART_FirstSpacer"
                                   Grid.Column="1"
                                   Width="{DynamicResource DatePickerSpacerThemeThickness}"
                                   HorizontalAlignment="Center"
                                   Fill="{DynamicResource SynthoraBorderBrush}" />
                        <Rectangle Name="PART_SecondSpacer"
                                   Grid.Column="3"
                                   Width="{DynamicResource DatePickerSpacerThemeThickness}"
                                   HorizontalAlignment="Center"
                                   Fill="{DynamicResource SynthoraBorderBrush}" />
                    </Grid>

                    <Grid Name="AcceptDismissGrid"
                          Grid.Row="1"
                          ColumnDefinitions="*,*">
                        <Rectangle Grid.ColumnSpan="2"
                                   Height="{DynamicResource DatePickerSpacerThemeThickness}"
                                   VerticalAlignment="Top"
                                   Fill="{DynamicResource SynthoraBorderBrush}" />
                        <Button Name="PART_AcceptButton"
                                Grid.Column="0"
                                Height="{DynamicResource DatePickerFlyoutPresenterAcceptDismissHostGridHeight}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                FocusAttach.FocusOnLoaded="True"
                                IsDefault="True"
                                Theme="{StaticResource SimpleDateTimePickerButtonTheme}">
                            <Path Data="M0.5,7.0 5,12.0 15.5,1.5"
                                  Stroke="{Binding $parent[Button].Foreground}"
                                  StrokeLineCap="Round"
                                  StrokeThickness="0.75" />
                        </Button>
                        <Button Name="PART_DismissButton"
                                Grid.Column="1"
                                Height="{DynamicResource DatePickerFlyoutPresenterAcceptDismissHostGridHeight}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                IsCancel="True"
                                Theme="{StaticResource SimpleDateTimePickerButtonTheme}">
                            <Path Data="M2,2 14,14 M2,14 14 2"
                                  Stroke="{Binding $parent[Button].Foreground}"
                                  StrokeLineCap="Round"
                                  StrokeThickness="0.75" />
                        </Button>
                    </Grid>
                </Grid>
            </ControlTemplate>
        </Setter>

        <Style Selector="^ /template/ Panel">
            <Style Selector="^:pointerover RepeatButton">
                <Setter Property="IsVisible" Value="True" />
            </Style>
        </Style>
    </ControlTheme>

</ResourceDictionary>