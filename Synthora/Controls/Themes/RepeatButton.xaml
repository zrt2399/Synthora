<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    x:ClassModifier="internal"
                    x:CompileBindings="True">

    <ControlTheme x:Key="OutlineRepeatButtonTheme"
                  BasedOn="{StaticResource OutlineButtonTheme}"
                  TargetType="RepeatButton" />

    <ControlTheme x:Key="{x:Type RepeatButton}"
                  BasedOn="{StaticResource OutlineRepeatButtonTheme}"
                  TargetType="RepeatButton" />

    <ControlTheme x:Key="SolidRepeatButtonTheme"
                  BasedOn="{StaticResource SolidButtonTheme}"
                  TargetType="RepeatButton" />

    <ControlTheme x:Key="BorderlessRepeatButtonTheme"
                  BasedOn="{StaticResource BorderlessButtonTheme}"
                  TargetType="RepeatButton" />

</ResourceDictionary>