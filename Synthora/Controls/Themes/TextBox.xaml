<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="using:System"
                    x:ClassModifier="internal"
                    x:CompileBindings="True">

    <Design.PreviewWith>
        <Border Padding="20">
            <StackPanel Spacing="20">
                <TextBox Foreground="OrangeRed">Left</TextBox>
                <TextBox BorderBrush="Blue" TextAlignment="Center">Center</TextBox>
                <TextBox Classes="clearButton">Clear</TextBox>
                <TextBox Classes="revealPasswordButton" PasswordChar="*">Reveal Password</TextBox>
                <TextBox Classes="revealPasswordButton"
                         PasswordChar="*"
                         RevealPassword="True">
                    Password Revealed
                </TextBox>
                <TextBox PlaceholderText="Placeholder" />
                <TextBox>
                    Error
                    <DataValidationErrors.Error>
                        <sys:Exception>
                            <x:Arguments>
                                <x:String>Error</x:String>
                            </x:Arguments>
                        </sys:Exception>
                    </DataValidationErrors.Error>
                </TextBox>
                <TextBox PlaceholderText="Floating Placeholder" UseFloatingPlaceholder="True">Content</TextBox>
            </StackPanel>
        </Border>
    </Design.PreviewWith>

