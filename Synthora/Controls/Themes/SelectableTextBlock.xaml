<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    x:ClassModifier="internal"
                    x:CompileBindings="True">

    <Design.PreviewWith>
        <SelectableTextBlock Text="Preview" />
    </Design.PreviewWith>

    <MenuFlyout x:Key="DefaultSelectableTextBlockContextFlyout">
        <MenuItem Command="{Binding $parent[SelectableTextBlock].Copy}"
                  Header="{DynamicResource StringTextFlyoutCopyText}"
                  Icon="{StaticResource TextCopyIcon}"
                  InputGesture="{x:Static TextBox.CopyGesture}"
                  IsEnabled="{Binding $parent[SelectableTextBlock].CanCopy}" />
        <MenuItem Command="{Binding $parent[SelectableTextBlock].SelectAll}"
                  Header="{DynamicResource StringTextFlyoutSelectAllText}"
                  InputGesture="{x:Static GestureUtils.SelectAllGesture}">
            <MenuItem.IsEnabled>
                <MultiBinding Converter="{x:Static SynthoraConverters.TextBlockHasContentConverter}">
                    <Binding Path="$parent[SelectableTextBlock].Text" />
                    <Binding Path="$parent[SelectableTextBlock].Inlines?.Count" />
                </MultiBinding>
            </MenuItem.IsEnabled>
        </MenuItem>
    </MenuFlyout>

    <MenuFlyout x:Key="HorizontalSelectableTextBlockContextFlyout"
                FlyoutPresenterTheme="{DynamicResource HorizontalMenuFlyoutPresenter}"
                ItemContainerTheme="{DynamicResource HorizontalMenuItem}"
                ShowMode="{OnFormFactor Desktop=Standard,
                                        Mobile=Transient}">
        <MenuItem Command="{Binding $parent[SelectableTextBlock].Copy}"
                  Header="{DynamicResource StringTextFlyoutCopyText}"
                  IsEnabled="{Binding $parent[SelectableTextBlock].CanCopy}" />
        <MenuItem Command="{Binding $parent[SelectableTextBlock].SelectAll}"
                  Header="{DynamicResource StringTextFlyoutSelectAllText}"
                  InputGesture="{x:Static GestureUtils.SelectAllGesture}">
            <MenuItem.IsEnabled>
                <MultiBinding Converter="{x:Static SynthoraConverters.TextBlockHasContentConverter}">
                    <Binding Path="$parent[SelectableTextBlock].Text" />
                    <Binding Path="$parent[SelectableTextBlock].Inlines?.Count" />
                </MultiBinding>
            </MenuItem.IsEnabled>
        </MenuItem>
    </MenuFlyout>

    <ControlTheme x:Key="{x:Type SelectableTextBlock}"
                  BasedOn="{StaticResource {x:Type TextBlock}}"
                  TargetType="SelectableTextBlock">
        <Setter Property="SelectionBrush" Value="{DynamicResource TextSelectionBrush}" />
        <Setter Property="ContextFlyout" Value="{OnFormFactor Desktop={StaticResource DefaultSelectableTextBlockContextFlyout}, Mobile={StaticResource HorizontalSelectableTextBlockContextFlyout}}" />

        <Style Selector="^:pointerover">
            <Setter Property="Cursor" Value="IBeam" />
        </Style>
    </ControlTheme>

</ResourceDictionary>