<UserControl x:Class="Synthora.Demo.Views.ScrollViewerView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Synthora.Demo.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:DataType="vm:ScrollViewerViewModel"
             mc:Ignorable="d">

    <DemoPage Title="ScrollViewer"
              Description="{Binding Description}"
              IconKind="{Binding IconKind}">
        <StackPanel Spacing="16">
            <Border Classes="card">
                <ScrollViewer>
                    <StackPanel HorizontalAlignment="Left" Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <CheckBox Name="autoHide" IsChecked="True">Allow AutoHide</CheckBox>
                            <ComboBox Name="orientation"
                                      ItemsSource="{EnumBindingSource Orientation}"
                                      SelectedItem="{x:Static Orientation.Vertical}"
                                      TextBoxAttach.Header="Orientation: "
                                      TextBoxAttach.HeaderPlacement="Left" />
                        </StackPanel>

                        <ScrollViewer Width="600"
                                      Height="400"
                                      AllowAutoHide="{Binding #autoHide.IsChecked}"
                                      HorizontalScrollBarVisibility="Auto"
                                      ScrollViewerAttach.Orientation="{Binding #orientation.SelectedItem}">
                            <UniformGrid Width="1000"
                                         Height="800"
                                         Columns="2"
                                         Rows="2">
                                <Rectangle Fill="#DCEBFF" />
                                <Rectangle Fill="#DDF6E8" />
                                <Rectangle Fill="#FFE7CC" />
                                <Rectangle Fill="#E9DDFB" />
                            </UniformGrid>
                        </ScrollViewer>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </StackPanel>
    </DemoPage>
</UserControl>