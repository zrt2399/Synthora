<UserControl x:Class="Synthora.Demo.Views.DataGridView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Synthora.Demo.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:DataType="vm:DataGridViewModel"
             mc:Ignorable="d">

    <UserControl.Styles>
        <Style Selector="DataGrid.hasShadow">
            <Setter Property="BoxShadowAttach.BoxShadow" Value="{DynamicResource DefaultBoxShadow}" />
        </Style>
        <Style Selector="DataGrid.borderless">
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </UserControl.Styles>

    <DemoPage Title="Data Grid"
              Padding="0"
              Description="Inspect grouping, styling and interaction states for tabular data."
              IconKind="{Binding IconKind}">
        <TabControl Padding="16">
            <TabControl.Styles>
                <Style Selector="DataGrid">
                    <Setter Property="CornerRadius" Value="12" />
                    <Setter Property="AutoGenerateColumns" Value="True" />
                    <!--<Styles>
                        <Style Selector="DataGridRow:nth-child(even)">
                            <Setter Property="Background" Value="{DynamicResource SynthoraMidBrush}" />
                        </Style>
                    </Styles>-->
                </Style>
            </TabControl.Styles>

            <TabItem Header="Grouping">
                <DataGrid x:Name="dataGrid"
                          HeadersVisibility="All"
                          ItemsSource="{Binding DataGridCollectionView}" />
            </TabItem>

            <TabItem Header="Styling">
                <DockPanel HorizontalSpacing="16" VerticalSpacing="16">
                    <WrapPanel DockPanel.Dock="Top"
                               ItemSpacing="16"
                               LineSpacing="16"
                               Orientation="Horizontal">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <CheckBox Name="borderless"
                                      Content="Borderless"
                                      IsChecked="True" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock VerticalAlignment="Center">
                                    <Run>CornerRadius:</Run>
                                    <Run Text="{Binding #Slider.Value}" />
                                </TextBlock>
                                <Slider Name="Slider"
                                        Width="100"
                                        IsSnapToTickEnabled="True"
                                        Maximum="20"
                                        TickFrequency="1" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <CheckBox Name="hasShadow"
                                      Content="Shadow"
                                      IsChecked="True" />
                            <CheckBox Content="AllowAutoHide" IsChecked="{Binding #dataGridEmployees.(ScrollViewer.AllowAutoHide)}" />
                            <CheckBox Content="IsReadOnly" IsChecked="{Binding #dataGridEmployees.IsReadOnly}" />
                            <ComboBox ItemsSource="{EnumBindingSource DataGridGridLinesVisibility}"
                                      SelectedItem="{Binding #dataGridEmployees.GridLinesVisibility}"
                                      TextBoxAttach.Header="GridLinesVisibility: "
                                      TextBoxAttach.HeaderPlacement="Left" />
                            <Button Command="{Binding ClearEmployees}" Theme="{StaticResource WarningButtonTheme}">Clear</Button>
                            <Button Command="{Binding ResetEmployees}" Theme="{StaticResource DangerButtonTheme}">Reset</Button>
                        </StackPanel>
                    </WrapPanel>
                    <DataGrid Name="dataGridEmployees"
                              Classes.borderless="{Binding #borderless.IsChecked}"
                              Classes.hasShadow="{Binding #hasShadow.IsChecked}"
                              CornerRadius="{Binding #Slider.Value, Converter={x:Static SynthoraConverters.DoubleToCornerRadiusConverter}}"
                              ItemsSource="{Binding Employees}" />
                </DockPanel>
            </TabItem>
        </TabControl>
    </DemoPage>

</UserControl>