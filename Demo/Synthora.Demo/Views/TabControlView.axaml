<UserControl x:Class="Synthora.Demo.Views.TabControlView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Synthora.Demo.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:DataType="vm:TabControlViewModel"
             mc:Ignorable="d">

    <DemoPage Title="Tab Controls"
              Description="{Binding Description}"
              IconKind="{Binding IconKind}">
        <DockPanel VerticalSpacing="16">
            <WrapPanel DockPanel.Dock="Top"
                       ItemSpacing="16"
                       LineSpacing="16"
                       Orientation="Horizontal">
                <CheckBox Name="ShowHeaderSeparator" IsChecked="True">ShowHeaderSeparator</CheckBox>
                <CheckBox Name="ShowHeaderShadow" IsChecked="True">ShowHeaderShadow</CheckBox>
                <CheckBox Name="Primary">Primary</CheckBox>
                <CheckBox Name="Secondary">Secondary</CheckBox>
                <ComboBox Name="TabStripPlacement"
                          ItemsSource="{EnumBindingSource Dock}"
                          SelectedItem="{x:Static Dock.Top}"
                          TextBoxAttach.Header="TabStripPlacement:"
                          TextBoxAttach.HeaderPlacement="Left" />
                <ComboBox Name="HorizontalHeaderAlignment"
                          ItemsSource="{EnumBindingSource HorizontalAlignment}"
                          SelectedItem="{x:Static HorizontalAlignment.Left}"
                          TextBoxAttach.Header="HorizontalHeaderAlignment:"
                          TextBoxAttach.HeaderPlacement="Left" />
                <ComboBox Name="VerticalHeaderAlignment"
                          ItemsSource="{EnumBindingSource VerticalAlignment}"
                          SelectedItem="{x:Static VerticalAlignment.Top}"
                          TextBoxAttach.Header="VerticalHeaderAlignment:"
                          TextBoxAttach.HeaderPlacement="Left" />
            </WrapPanel>
            <UniformGrid Columns="1" RowSpacing="16">
                <TabControl Classes.Secondary="{Binding #Secondary.IsChecked}"
                            TabControlAttach.HorizontalHeaderAlignment="{Binding #HorizontalHeaderAlignment.SelectedItem}"
                            TabControlAttach.ShowHeaderSeparator="{Binding #ShowHeaderSeparator.IsChecked}"
                            TabControlAttach.ShowHeaderShadow="{Binding #ShowHeaderShadow.IsChecked}"
                            TabControlAttach.VerticalHeaderAlignment="{Binding #VerticalHeaderAlignment.SelectedItem}"
                            TabStripPlacement="{Binding #TabStripPlacement.SelectedItem}">
                    <TabItem Header="Tab 1">
                        <SelectableTextBlock>DefaultTheme</SelectableTextBlock>
                    </TabItem>
                    <TabItem Header="Tab 2" IsEnabled="False">
                        <SelectableTextBlock>Content 2</SelectableTextBlock>
                    </TabItem>
                    <TabItem Header="Tab 3">
                        <SelectableTextBlock>Content 3</SelectableTextBlock>
                    </TabItem>
                    <TabItem Header="Tab 4">
                        <SelectableTextBlock>Content 4</SelectableTextBlock>
                    </TabItem>
                </TabControl>
                <TabControl Classes.Primary="{Binding #Primary.IsChecked}"
                            TabControlAttach.HorizontalHeaderAlignment="{Binding #HorizontalHeaderAlignment.SelectedItem}"
                            TabControlAttach.ShowHeaderSeparator="{Binding #ShowHeaderSeparator.IsChecked}"
                            TabControlAttach.ShowHeaderShadow="{Binding #ShowHeaderShadow.IsChecked}"
                            TabControlAttach.VerticalHeaderAlignment="{Binding #VerticalHeaderAlignment.SelectedItem}"
                            TabStripPlacement="{Binding #TabStripPlacement.SelectedItem}"
                            Theme="{StaticResource SegmentedTabControlTheme}">
                    <TabItem Header="Tab 1">
                        <SelectableTextBlock>SegmentedTabControlTheme</SelectableTextBlock>
                    </TabItem>
                    <TabItem Header="Tab 2" IsEnabled="False">
                        <SelectableTextBlock>Content 2</SelectableTextBlock>
                    </TabItem>
                    <TabItem Header="Tab 3">
                        <SelectableTextBlock>Content 3</SelectableTextBlock>
                    </TabItem>
                    <TabItem Header="Tab 4">
                        <SelectableTextBlock>Content 4</SelectableTextBlock>
                    </TabItem>
                </TabControl>
                <TabControl Classes="Uniform"
                            Classes.Primary="{Binding #Primary.IsChecked}"
                            TabControlAttach.ShowHeaderSeparator="{Binding #ShowHeaderSeparator.IsChecked}"
                            TabControlAttach.ShowHeaderShadow="{Binding #ShowHeaderShadow.IsChecked}"
                            TabStripPlacement="{Binding #TabStripPlacement.SelectedItem}"
                            Theme="{StaticResource SegmentedTabControlTheme}">
                    <TabItem Header="Tab 1">
                        <SelectableTextBlock>SegmentedTabControlTheme with Classes Uniform</SelectableTextBlock>
                    </TabItem>
                    <TabItem Header="Tab 2" IsEnabled="False">
                        <SelectableTextBlock>Content 2</SelectableTextBlock>
                    </TabItem>
                    <TabItem Header="Tab 3">
                        <SelectableTextBlock>Content 3</SelectableTextBlock>
                    </TabItem>
                    <TabItem Header="Tab 4">
                        <SelectableTextBlock>Content 4</SelectableTextBlock>
                    </TabItem>
                </TabControl>
                <TabControl Classes.Primary="{Binding #Primary.IsChecked}"
                            TabControlAttach.HorizontalHeaderAlignment="{Binding #HorizontalHeaderAlignment.SelectedItem}"
                            TabControlAttach.ShowHeaderSeparator="{Binding #ShowHeaderSeparator.IsChecked}"
                            TabControlAttach.ShowHeaderShadow="{Binding #ShowHeaderShadow.IsChecked}"
                            TabControlAttach.VerticalHeaderAlignment="{Binding #VerticalHeaderAlignment.SelectedItem}"
                            TabStripPlacement="{Binding #TabStripPlacement.SelectedItem}"
                            Theme="{StaticResource CardTabControlTheme}">
                    <TabItem Header="Tab 1">
                        <SelectableTextBlock>CardTabControlTheme</SelectableTextBlock>
                    </TabItem>
                    <TabItem Header="Tab 2" IsEnabled="False">
                        <SelectableTextBlock>Content 2</SelectableTextBlock>
                    </TabItem>
                    <TabItem Header="Tab 3">
                        <SelectableTextBlock>Content 3</SelectableTextBlock>
                    </TabItem>
                    <TabItem Header="Tab 4">
                        <SelectableTextBlock>Content 4</SelectableTextBlock>
                    </TabItem>
                </TabControl>
            </UniformGrid>
        </DockPanel>
    </DemoPage>

</UserControl>