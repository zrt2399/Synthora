<UserControl x:Class="Synthora.Demo.Views.TextBlockView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Synthora.Demo.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:DataType="vm:TextBlockViewModel"
             mc:Ignorable="d">

    <DemoPage Title="Text Blocks"
              Padding="0"
              Description="{Binding Description}"
              IconKind="{Binding IconKind}">
        <ScrollViewer Padding="16">
            <StackPanel Spacing="16">
                <Border Classes="card">
                    <StackPanel Spacing="16">
                        <StackPanel Classes="sectionHeader">
                            <materialIcons:MaterialIcon Classes="sectionIcon" Kind="FormatText" />
                            <TextBlock Classes="sectionLabel" Text="TEXTBLOCK" />
                        </StackPanel>
                        <UniformGrid Rows="1">
                            <TextBlock Classes="H1">H1</TextBlock>
                            <TextBlock Classes="H2">H2</TextBlock>
                            <TextBlock Classes="H3">H3</TextBlock>
                            <TextBlock Classes="H4">H4</TextBlock>
                            <TextBlock Classes="H5">H5</TextBlock>
                            <TextBlock Classes="H6">H6</TextBlock>
                        </UniformGrid>
                        <Grid ColumnDefinitions="*,16,*">
                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock Classes="sectionLabel" Text="INLINE FORMATTING" />
                                <Border Padding="8"
                                        Classes="card"
                                        CornerRadius="6">
                                    <TextBlock Name="InlineTextBlock" TextWrapping="Wrap">
                                        <Run Text="Combine" />
                                        <Run FontWeight="Bold" Text="Bold" />
                                        <Run Text="," />
                                        <Run FontStyle="Italic" Text="Italic" />
                                        <Run Text="," />
                                        <Run Text="Strikethrough" TextDecorations="Strikethrough" />
                                        <Run Text="," />
                                        <Run Text="Overline" TextDecorations="Overline" />
                                        <Run Text="," />
                                        <Run Text="Baseline" TextDecorations="Baseline" />
                                        <Run Text=", and" />
                                        <Run Text="Underline" TextDecorations="Underline" />
                                        <Run Foreground="{DynamicResource PrimaryBrush}" Text=" runs to present rich explanatory copy." />
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="8">
                                <TextBlock Classes="sectionLabel" Text="TRIMMING" />
                                <Border Padding="8"
                                        Classes="card"
                                        CornerRadius="6">
                                    <TextBlock MaxLines="2"
                                               Text="{Binding WrappingSample}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Classes="card">
                    <StackPanel Spacing="16">
                        <StackPanel Classes="sectionHeader">
                            <materialIcons:MaterialIcon Classes="sectionIcon" Kind="CursorText" />
                            <TextBlock Classes="sectionLabel" Text="SELECTABLETEXTBLOCK" />
                        </StackPanel>
                        <UniformGrid Rows="1">
                            <SelectableTextBlock Classes="H1">H1</SelectableTextBlock>
                            <SelectableTextBlock Classes="H2">H2</SelectableTextBlock>
                            <SelectableTextBlock Classes="H3">H3</SelectableTextBlock>
                            <SelectableTextBlock Classes="H4">H4</SelectableTextBlock>
                            <SelectableTextBlock Classes="H5">H5</SelectableTextBlock>
                            <SelectableTextBlock Classes="H6">H6</SelectableTextBlock>
                        </UniformGrid>
                        <Grid ColumnDefinitions="*,16,*">
                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock Classes="sectionLabel" Text="COPYABLE CONTENT" />
                                <Border Padding="8"
                                        Classes="card"
                                        CornerRadius="6">
                                    <SelectableTextBlock Inlines="{Binding #InlineTextBlock.Inlines}" TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="8">
                                <TextBlock Classes="sectionLabel" Text="CODE-LIKE SAMPLE" />
                                <Border Padding="8"
                                        Classes="card"
                                        CornerRadius="6">
                                    <SelectableTextBlock FontFamily="Cascadia Mono,Consolas,SF Mono,Menlo,monospace"
                                                         Text="{Binding CodeSample}"
                                                         TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DemoPage>
</UserControl>