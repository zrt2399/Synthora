<UserControl x:Class="Synthora.Demo.Views.ExtendedControlsView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Synthora.Demo.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:DataType="vm:ExtendedControlsViewModel"
             mc:Ignorable="d">

    <DemoPage Title="Extended Controls"
              Padding="0"
              Description="{Binding Description}"
              IconKind="{Binding IconKind}">
        <ScrollViewer Padding="16">
            <StackPanel Spacing="16">
                <!--  Tag showcase  -->
                <Border Classes="card">
                    <StackPanel Spacing="16">
                        <StackPanel Classes="sectionHeader">
                            <materialIcons:MaterialIcon Classes="sectionIcon" Kind="Label" />
                            <TextBlock Classes="sectionLabel" Text="TAG" />
                        </StackPanel>
                        <SpacingWrapPanel HorizontalSpacing="16" VerticalSpacing="16">
                            <Tag>enhancement</Tag>
                            <Tag TagType="Question">question</Tag>
                            <Tag TagType="Success">ready</Tag>
                            <Tag TagType="Warning">needs info</Tag>
                            <Tag TagType="Danger">security</Tag>
                            <Tag TagType="Error">bug</Tag>
                            <Tag TagType="None">wontfix</Tag>
                        </SpacingWrapPanel>
                        <SpacingWrapPanel HorizontalSpacing="16" VerticalSpacing="16">
                            <Tag IsSolid="True">documentation</Tag>
                            <Tag IsSolid="True" TagType="Question">discussion</Tag>
                            <Tag IsSolid="True" TagType="Success">good first issue</Tag>
                            <Tag IsSolid="True" TagType="Warning">help wanted</Tag>
                            <Tag IsSolid="True" TagType="Danger">breaking change</Tag>
                            <Tag IsSolid="True" TagType="Error">regression</Tag>
                            <Tag IsSolid="True" TagType="None">duplicate</Tag>
                        </SpacingWrapPanel>
                        <SpacingWrapPanel HorizontalSpacing="16" VerticalSpacing="16">
                            <Tag IsCircular="True" IsSolid="True">triage</Tag>
                            <Tag IsCircular="True" TagType="Question">needs answer</Tag>
                            <Tag IsCircular="True"
                                 IsSolid="True"
                                 TagType="Success">
                                approved
                            </Tag>
                            <Tag IsCircular="True" TagType="Warning">blocked</Tag>
                            <Tag IsCircular="True"
                                 IsSolid="True"
                                 TagType="Danger">
                                critical
                            </Tag>
                            <Tag IsCircular="True" TagType="Error">failed</Tag>
                            <Tag TagType="None">archived</Tag>
                        </SpacingWrapPanel>
                    </StackPanel>
                </Border>

                <!--  StatusIndicator showcase  -->
                <Border Classes="card">
                    <StackPanel Spacing="16">
                        <StackPanel Classes="sectionHeader">
                            <materialIcons:MaterialIcon Classes="sectionIcon" Kind="CircleSlice8" />
                            <TextBlock Classes="sectionLabel" Text="STATUS INDICATOR" />
                        </StackPanel>
                        <SpacingWrapPanel HorizontalSpacing="16" VerticalSpacing="16">
                            <StatusIndicator IconType="Information" />
                            <StatusIndicator IconType="Question" />
                            <StatusIndicator IconType="Success" />
                            <StatusIndicator IconType="Warning" />
                            <StatusIndicator IconType="Error" />
                            <StatusIndicator />
                        </SpacingWrapPanel>
                        <SpacingWrapPanel HorizontalSpacing="16" VerticalSpacing="16">
                            <StatusIndicator IconType="Success" StrokeThickness="1">Content</StatusIndicator>
                            <StatusIndicator IconType="Success" StrokeThickness="2" />
                            <StatusIndicator HighlightMargin="6"
                                             IconType="Success"
                                             StrokeThickness="4" />
                            <StatusIndicator BorderBrush="{DynamicResource WarningBrush}"
                                             IconType="Warning"
                                             StrokeThickness="3" />
                            <StatusIndicator HighlightMargin="2"
                                             IconHeight="12"
                                             IconType="Error"
                                             IconWidth="12"
                                             StrokeThickness="0" />
                        </SpacingWrapPanel>
                    </StackPanel>
                </Border>

                <!--  ShadowChrome showcase  -->
                <Border Classes="card">
                    <StackPanel Spacing="16">
                        <StackPanel Classes="sectionHeader">
                            <materialIcons:MaterialIcon Classes="sectionIcon" Kind="BoxShadow" />
                            <TextBlock Classes="sectionLabel" Text="SHADOW CHROME" />
                        </StackPanel>
                        <ContentControl>
                            <GroupBoxEx>
                                <GroupBoxEx>
                                    <ShadowChrome Padding="8">
                                        <ShadowChrome>
                                            <SelectableTextBlock>ShadowChrome nested</SelectableTextBlock>
                                        </ShadowChrome>
                                    </ShadowChrome>
                                </GroupBoxEx>
                            </GroupBoxEx>
                        </ContentControl>
                        <ShadowChrome>
                            <TextBlock Margin="8">ShadowChrome standalone</TextBlock>
                        </ShadowChrome>
                        <ShadowChrome ShowShadowOnInteraction="True">
                            <TextBlock Margin="8">ShadowChrome with  ShowShadowOnPointerOver</TextBlock>
                        </ShadowChrome>
                        <ShadowChrome InteractionBoxShadow="0 0 12 0 #FF695AEE" ShowShadowOnInteraction="True">
                            <TextBlock Margin="8">ShadowChrome with ShowShadowOnPointerOver and custom box shadow</TextBlock>
                        </ShadowChrome>
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <GroupBoxEx Width="120" Header="GroupBoxEx">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock>TextBlockTextBlock</TextBlock>
                                </StackPanel>
                            </GroupBoxEx>
                            <Expander Header="Expander">Content</Expander>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  PathPicker  -->
                <Border Classes="card">
                    <StackPanel Spacing="16">
                        <StackPanel Classes="sectionHeader">
                            <materialIcons:MaterialIcon Classes="sectionIcon" Kind="FolderOpen" />
                            <TextBlock Classes="sectionLabel" Text="FILE PICKER" />
                        </StackPanel>
                        <PathPicker PlaceholderText="Pick a folder"
                                    TextBoxAttach.Header="PathPicker(Folder)"
                                    UseFolderDialog="True" />
                        <PathPicker AllowMultiple="True"
                                    FilePickerFileTypes="{Binding FilePickerFileTypes}"
                                    PlaceholderText="Pick files"
                                    SelectedPaths="{Binding SelectedFiles}"
                                    TextBoxAttach.Header="PathPicker(Multiple Files)" />
                    </StackPanel>
                </Border>

                <!--  SpacingWrapPanel  -->
                <Border Classes="card">
                    <StackPanel Spacing="16">
                        <StackPanel Classes="sectionHeader">
                            <materialIcons:MaterialIcon Classes="sectionIcon" Kind="ViewDashboard" />
                            <TextBlock Classes="sectionLabel" Text="SPACING WRAPPANEL" />
                        </StackPanel>
                        <SpacingWrapPanel HorizontalSpacing="16" VerticalSpacing="16">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center">TextBlock</TextBlock>
                                <TextBox Margin="6,0,0,0">TextBox</TextBox>
                            </StackPanel>
                            <Button>Button</Button>
                            <ComboBox SelectedIndex="0">
                                <ComboBoxItem>ComboBoxItem-1</ComboBoxItem>
                                <ComboBoxItem>ComboBoxItem-2</ComboBoxItem>
                            </ComboBox>
                            <DropDownButton>DropDownButton</DropDownButton>
                        </SpacingWrapPanel>
                    </StackPanel>
                </Border>

                <!--  EmptyBox  -->
                <Border Classes="card">
                    <StackPanel Spacing="16">
                        <StackPanel Classes="sectionHeader">
                            <materialIcons:MaterialIcon Classes="sectionIcon" Kind="PackageVariant" />
                            <TextBlock Classes="sectionLabel" Text="EMPTY BOX" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <EmptyBox />
                            <EmptyBox IconHeight="60" IconWidth="90" />
                            <EmptyBox IconHeight="80" IconWidth="120" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DemoPage>
</UserControl>