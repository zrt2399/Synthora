<UserControl x:Class="Synthora.Demo.Views.InputView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Synthora.Demo.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:DataType="vm:InputViewModel"
             mc:Ignorable="d">

    <DemoPage Title="Input Controls"
              Padding="0"
              Description="{Binding Description}"
              IconKind="{Binding IconKind}">
        <ScrollViewer Padding="16">
            <StackPanel Spacing="16">
                <Border Classes="card">
                    <StackPanel Spacing="16">
                        <StackPanel Classes="sectionHeader">
                            <materialIcons:MaterialIcon Classes="sectionIcon" Kind="TextBoxOutline" />
                            <TextBlock Classes="sectionLabel" Text="TEXT INPUT" />
                        </StackPanel>
                        <AutoCompleteBox FilterMode="Contains"
                                         ItemsSource="{Binding AutoCompleteSuggestions}"
                                         MinimumPrefixLength="1"
                                         Text="{Binding AutoCompleteText}"
                                         TextBoxAttach.Header="AutoCompleteBox" />
                        <TextBox InnerRightContent="Ω"
                                 PlaceholderText="Type a message"
                                 Text="{Binding Greeting}"
                                 TextAlignment="Right"
                                 TextBoxAttach.Header="TextBox(With InnerRightContent)"
                                 TextWrapping="Wrap"
                                 UseFloatingPlaceholder="True" />
                        <UniformGrid ColumnSpacing="16"
                                     Columns="2"
                                     RowSpacing="16">
                            <TextBox Text="TextBox" TextBoxAttach.Header="TextBox" />
                            <TextBox IsReadOnly="True"
                                     Text="ReadOnly"
                                     TextBoxAttach.Header="TextBox(ReadOnly)" />
                            <TextBox MaxHeight="100"
                                     AcceptsReturn="True"
                                     Classes="clearButton"
                                     Text="{Binding Value}"
                                     TextBoxAttach.Header="Multiline TextBox(With clearButton)" />
                            <TextBox Classes="clearButton revealPasswordButton" TextBoxAttach.Header="PasswordBox(With clearButton)" />
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Classes="card">
                    <StackPanel Spacing="16">
                        <StackPanel Classes="sectionHeader">
                            <materialIcons:MaterialIcon Classes="sectionIcon" Kind="FormatListNumbered" />
                            <TextBlock Classes="sectionLabel" Text="NUMERIC &amp; SPINNER" />
                        </StackPanel>
                        <Grid ColumnDefinitions="*,16,*" RowDefinitions="Auto,16,Auto">
                            <ButtonSpinner Grid.Row="0"
                                           Grid.Column="0"
                                           AllowSpin="False"
                                           ButtonSpinnerLocation="Left"
                                           TextBoxAttach.Header="ButtonSpinner(Left)">
                                ButtonSpinner(Left)
                            </ButtonSpinner>
                            <ButtonSpinner Grid.Row="0"
                                           Grid.Column="2"
                                           TextBoxAttach.Header="ButtonSpinner(Right)">
                                ButtonSpinner(Right)
                            </ButtonSpinner>
                            <NumericUpDown Grid.Row="2"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="3"
                                           Increment="1"
                                           TextBoxAttach.Header="NumericUpDown"
                                           Value="12" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Classes="card">
                    <StackPanel Spacing="16">
                        <StackPanel Classes="sectionHeader">
                            <materialIcons:MaterialIcon Classes="sectionIcon" Kind="SelectArrowDown" />
                            <TextBlock Classes="sectionLabel" Text="COMBOBOX" />
                        </StackPanel>
                        <ComboBox IsEditable="True"
                                  PlaceholderText="Search a region..."
                                  TextBoxAttach.Header="Region"
                                  TextBoxAttach.IsRequired="True">
                            <ComboBoxItem>United States</ComboBoxItem>
                            <ComboBoxItem>Canada</ComboBoxItem>
                            <ComboBoxItem>United Kingdom</ComboBoxItem>
                            <ComboBoxItem>Germany</ComboBoxItem>
                            <ComboBoxItem>France</ComboBoxItem>
                            <ComboBoxItem>Japan</ComboBoxItem>
                            <ComboBoxItem>Singapore</ComboBoxItem>
                            <ComboBoxItem>Australia</ComboBoxItem>
                            <ComboBoxItem>China</ComboBoxItem>
                            <ComboBoxItem>South Korea</ComboBoxItem>
                            <ComboBoxItem>India</ComboBoxItem>
                            <ComboBoxItem>Brazil</ComboBoxItem>
                            <ComboBoxItem>Mexico</ComboBoxItem>
                            <ComboBoxItem>Netherlands</ComboBoxItem>
                            <ComboBoxItem>Sweden</ComboBoxItem>
                            <ComboBoxItem>Italy</ComboBoxItem>
                            <ComboBoxItem>Spain</ComboBoxItem>
                        </ComboBox>
                        <ComboBox Classes="clearButton"
                                  ItemsSource="{Binding SystemFonts}"
                                  PlaceholderText="Choose a font..."
                                  SelectedIndex="0"
                                  TextBoxAttach.Header="System fonts(With clearButton)">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="FontFamily">
                                    <TextBlock FontFamily="{Binding}" Text="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <ComboBox ItemsSource="{EnumBindingSource ThemeMode}"
                                  SelectedItem="{Binding SelectedEnumDescriptionMode}"
                                  TextBoxAttach.Header="ComboBox(With GetDescription and EnumBindingSourceExtension)"
                                  WrapSelection="True">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={x:Static SynthoraConverters.EnumDescriptionConverter}, ConverterParameter={x:Type ThemeMode}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DemoPage>

</UserControl>