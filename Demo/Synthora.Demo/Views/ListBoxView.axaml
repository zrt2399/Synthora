<UserControl x:Class="Synthora.Demo.Views.ListBoxView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:icons="using:Material.Icons"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Synthora.Demo.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:DataType="vm:ListBoxViewModel"
             mc:Ignorable="d">

    <DemoPage Title="List Box"
              Description="{Binding Description}"
              IconKind="{Binding IconKind}">
        <Border Classes="card">
            <ListBox ItemsSource="{EnumBindingSource icons:MaterialIconKind}" />
        </Border>
    </DemoPage>

</UserControl>