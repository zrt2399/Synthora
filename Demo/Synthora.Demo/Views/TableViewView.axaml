<UserControl x:Class="Synthora.Demo.Views.TableViewView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Synthora.Demo.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:DataType="vm:TableViewViewModel"
             mc:Ignorable="d">

    <DemoPage Title="Table View"
              Padding="16"
              Description="{Binding Description}"
              IconKind="{Binding IconKind}">
        <Border Classes="card">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">
                <WrapPanel ItemSpacing="16"
                           LineSpacing="16"
                           Orientation="Horizontal">
                    <CheckBox Content="AllowAutoHide" IsChecked="{Binding #TableView.(ScrollViewer.AllowAutoHide)}" />
                    <CheckBox Name="Border" Content="Border" />
                    <CheckBox Name="Shadow" Content="Shadow" />
                    <CheckBox Content="CanUserResizeColumns" IsChecked="{Binding #TableView.CanUserResizeColumns}" />
                    <Button Classes="Warning"
                            Command="{Binding ClearEmployees}"
                            Theme="{StaticResource SolidButtonTheme}">
                        Clear
                    </Button>
                    <Button Classes="Error"
                            Command="{Binding ResetEmployees}"
                            Theme="{StaticResource SolidButtonTheme}">
                        Reset
                    </Button>
                </WrapPanel>

                <TableView Name="TableView"
                           Grid.Row="1"
                           Classes.Border="{Binding #Border.IsChecked}"
                           Classes.Shadow="{Binding #Shadow.IsChecked}"
                           ItemsSource="{Binding PagedEmployees}">
                    <TableView.Columns>
                        <TableViewColumn Width="72"
                                         Binding="{Binding Id}"
                                         Header="ID" />
                        <TableViewColumn Width="180"
                                         Binding="{Binding Name}"
                                         Header="Name" />
                        <TableViewColumn Width="240"
                                         Binding="{Binding Email}"
                                         Header="Email" />
                        <TableViewColumn Width="80"
                                         Binding="{Binding Age}"
                                         Header="Age" />
                        <TableViewColumn Width="120"
                                         Binding="{Binding Salary}"
                                         Header="Salary" />
                        <TableViewColumn Width="140"
                                         Binding="{Binding HireDate}"
                                         Header="Hire Date" />
                        <TableViewColumn Width="100"
                                         Binding="{Binding IsActive}"
                                         Header="Active" />
                    </TableView.Columns>
                </TableView>

                <Pagination Grid.Row="2"
                            PageSize="{Binding PageSize}"
                            ShowPageSizeSelector="True"
                            TotalItemCount="{Binding TotalItemCount}"
                            PageIndex="{Binding PageIndex}" />
            </Grid>
        </Border>
    </DemoPage>

</UserControl>