<UserControl x:Class="Synthora.Demo.Views.DrawerPageView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Synthora.Demo.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:DataType="vm:DrawerPageViewModel"
             mc:Ignorable="d">

    <DemoPage Title="Drawer Page"
              Description="{Binding Description}"
              IconKind="{Binding IconKind}">
        <DockPanel VerticalSpacing="16">
            <WrapPanel DockPanel.Dock="Top"
                       ItemSpacing="16"
                       LineSpacing="16"
                       Orientation="Horizontal">
                <CheckBox IsChecked="{Binding #drawerPage.IsOpen}">IsOpen</CheckBox>
                <ComboBox Name="drawerLayoutBehavior"
                          ItemsSource="{EnumBindingSource DrawerLayoutBehavior}"
                          SelectedItem="{Binding #drawerPage.DrawerLayoutBehavior}"
                          TextBoxAttach.Header="DrawerLayoutBehavior: "
                          TextBoxAttach.HeaderPlacement="Left" />
            </WrapPanel>
            <DrawerPage Name="drawerPage" Header="DrawerPage">
                <DrawerPage.Drawer>
                    <StackPanel Margin="0,16"
                                VerticalAlignment="Top"
                                Spacing="16">
                        <TextBlock HorizontalAlignment="Center" FontSize="13">Menu</TextBlock>
                        <Button>Item 1</Button>
                        <Button>Item 2</Button>
                        <Button>Item 3</Button>
                    </StackPanel>
                </DrawerPage.Drawer>
                Content
            </DrawerPage>
        </DockPanel>
    </DemoPage>

</UserControl>