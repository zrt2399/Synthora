<UserControl x:Class="Synthora.Demo.Views.TreeViewView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Synthora.Demo.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:DataType="vm:TreeViewViewModel"
             mc:Ignorable="d">

    <UserControl.Styles>
        <Style Selector="TreeView.SquareItems TreeViewItem">
            <Setter Property="CornerRadius" Value="0" />
        </Style>
    </UserControl.Styles>

    <DemoPage Title="Tree View"
              Description="{Binding Description}"
              IconKind="{Binding IconKind}">
        <Border Classes="card">
            <DockPanel HorizontalSpacing="16" VerticalSpacing="16">
                <WrapPanel DockPanel.Dock="Top"
                           ItemSpacing="16"
                           LineSpacing="16"
                           Orientation="Horizontal">
                    <CheckBox Name="Primary" Content="Primary" />
                    <CheckBox Name="Secondary" Content="Secondary" />
                    <CheckBox Name="Border" Content="Border" />
                    <CheckBox Name="Shadow" Content="Shadow" />
                    <CheckBox Name="SquareItems" Content="Square Items" />
                </WrapPanel>
                <TreeView Classes.Border="{Binding #Border.IsChecked}"
                          Classes.Primary="{Binding #Primary.IsChecked}"
                          Classes.Secondary="{Binding #Secondary.IsChecked}"
                          Classes.Shadow="{Binding #Shadow.IsChecked}"
                          Classes.SquareItems="{Binding #SquareItems.IsChecked}">
                    <TreeViewItem Header="Documents" IsExpanded="True">
                        <TreeViewItem Header="Work">
                            <TreeViewItem Header="ProjectProposal.docx" />
                            <TreeViewItem Header="QuarterlyReport.xlsx" />
                        </TreeViewItem>
                        <TreeViewItem Header="Personal">
                            <TreeViewItem Header="Resume.pdf" />
                            <TreeViewItem Header="Budget.xlsx" />
                        </TreeViewItem>
                    </TreeViewItem>
                    <TreeViewItem Header="Images" IsExpanded="True">
                        <TreeViewItem Header="Vacation">
                            <TreeViewItem Header="Beach.jpg" />
                            <TreeViewItem Header="Mountains.png" />
                        </TreeViewItem>
                        <TreeViewItem Header="Screenshots" />
                    </TreeViewItem>
                    <TreeViewItem Header="Downloads">
                        <TreeViewItem Header="Synthora-v1.0.zip" />
                        <TreeViewItem Header="Avalonia_Logo.svg" />
                    </TreeViewItem>
                </TreeView>
            </DockPanel>
        </Border>
    </DemoPage>

</UserControl>