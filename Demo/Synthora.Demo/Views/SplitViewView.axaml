<UserControl x:Class="Synthora.Demo.Views.SplitViewView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Synthora.Demo.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:DataType="vm:SplitViewViewModel"
             mc:Ignorable="d">

    <DemoPage Title="Split View"
              Description="{Binding Description}"
              IconKind="{Binding IconKind}">
        <DockPanel VerticalSpacing="16">
            <WrapPanel DockPanel.Dock="Top"
                       ItemSpacing="16"
                       LineSpacing="16"
                       Orientation="Horizontal">
                <CheckBox IsChecked="{Binding #splitView.IsPaneOpen}">IsPaneOpen</CheckBox>
                <CheckBox IsChecked="{Binding #splitView.UseLightDismissOverlayMode}">UseLightDismissOverlayMode</CheckBox>
                <ComboBox ItemsSource="{EnumBindingSource SplitViewDisplayMode}"
                          SelectedItem="{Binding #splitView.DisplayMode}"
                          TextBoxAttach.Header="SplitViewDisplayMode: "
                          TextBoxAttach.HeaderPlacement="Left" />
                <ComboBox ItemsSource="{EnumBindingSource SplitViewPanePlacement}"
                          SelectedItem="{Binding #splitView.PanePlacement}"
                          TextBoxAttach.Header="SplitViewPanePlacement: "
                          TextBoxAttach.HeaderPlacement="Left" />
            </WrapPanel>
            <SplitView Name="splitView"
                       CompactPaneLength="60"
                       DisplayMode="CompactOverlay"
                       OpenPaneLength="200">
                <SplitView.Pane>
                    <StackPanel VerticalAlignment="Top" Spacing="10">
                        <ToggleButton Content="{materialIcons:MaterialIconExt Kind=Menu}"
                                      CornerRadius="0"
                                      IsChecked="{Binding $parent[SplitView].IsPaneOpen}" />
                        <TextBlock HorizontalAlignment="Center">TabStrip</TextBlock>
                    </StackPanel>
                </SplitView.Pane>
                <TabStrip>
                    <TabStripItem>Tab 1</TabStripItem>
                    <TabStripItem IsEnabled="False">Tab 2</TabStripItem>
                    <TabStripItem>Tab 3</TabStripItem>
                    <TabStripItem>Tab 4</TabStripItem>
                </TabStrip>
            </SplitView>
        </DockPanel>
    </DemoPage>

</UserControl>