<UserControl x:Class="Synthora.Demo.Views.ScrollViewerView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Synthora.Demo.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:DataType="vm:ScrollViewerViewModel"
             mc:Ignorable="d">

    <DemoPage Title="Scroll Viewer"
              Description="{Binding Description}"
              IconKind="{Binding IconKind}">
        <StackPanel Spacing="16">
            <Border Classes="card">
                <ScrollViewer>
                    <StackPanel HorizontalAlignment="Left" Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <CheckBox Name="autoHide" IsChecked="True">Allow Auto Hide</CheckBox>
                            <ComboBox Name="orientation"
                                      ItemsSource="{EnumBindingSource Orientation}"
                                      SelectedItem="{x:Static Orientation.Vertical}"
                                      TextBoxAttach.Header="Orientation:"
                                      TextBoxAttach.HeaderPlacement="Left" />
                        </StackPanel>

                        <ScrollViewer Width="600"
                                      Height="400"
                                      AllowAutoHide="{Binding #autoHide.IsChecked}"
                                      HorizontalScrollBarVisibility="Auto"
                                      ScrollViewerAttach.Orientation="{Binding #orientation.SelectedItem}">
                            <Grid Width="1000"
                                  Height="800"
                                  ColumnDefinitions="*,Auto,*"
                                  RowDefinitions="*,Auto,*">
                                <Rectangle Fill="#336366F1" />
                                <GridSplitter Grid.Row="1" />
                                <Rectangle Grid.Row="2" Fill="#3322C55E" />
                                <GridSplitter Grid.RowSpan="3" Grid.Column="1" />
                                <Rectangle Grid.RowSpan="3"
                                           Grid.Column="2"
                                           Fill="#33F59E0B" />
                            </Grid>
                        </ScrollViewer>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </StackPanel>
    </DemoPage>

</UserControl>